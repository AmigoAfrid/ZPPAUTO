<mvc:View
    controllerName="zautodesignapp.controller.qa02.report.qa02_report"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

    <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="QA02 Report" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
								<layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false" class="sapUiSmallMarginBegin" />
                                    <DateRangeSelection id="Date" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value="" />

                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Batch No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialdocument" placeholder="Select Batch No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestQA02"  suggest=".OnSuggest_UserQA02" suggestionItems="{
                                        path: 'ZSB_AU_QA02_ITEM/ZC_AU_QA02ITEM',
                                        sorter: { path: 'batch' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedQA02">
                                    <suggestionItems>

                                    <core:Item key="{ZC_AU_QA02ITEM>batch}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>

                                    <layout:HorizontalLayout class=" sapUiLargeMarginBegin "><layout:HorizontalLayout class=" sapUiLargeMarginBegin "></layout:HorizontalLayout>


                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" /></layout:HorizontalLayout>

                                </layout:VerticalLayout>	
                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Process Ord No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idprocessorder" placeholder="Select Process Ord No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestQA02Proc"  suggest=".OnSuggest_UserQA02Proc" suggestionItems="{
                                        path: 'ZSB_AU_QA02_ITEM/ZC_AU_QA02ITEM',
                                        sorter: { path: 'processorder' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedQA02Proc">
                                    <suggestionItems>

                                    <core:Item key="{ZC_AU_QA02ITEM>processorder}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>
                                </layout:VerticalLayout>	

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table
                rows="{path:'TabModel>/ItemData', sorter: {path: 'TabModel>item1'}}"
                selectionMode="None"
                enableSelectAll="false"
                rowMode="Auto">
                <t:columns>
				
                    <t:Column tooltip="Date" width="6rem">
                        <Label text="Date" />
                        <t:template>
                            <Text text="{path:'TabModel>zdate',formatter: '.OnDateChangeValueQA02'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Batch" width="6rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{TabModel>batch}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Process Ord" width="6rem">
                        <Label text="Process Ord" />
                        <t:template>
                            <Text text="{TabModel>processorder}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Shift" width="auto">
                        <Label text="Shift" />
                        <t:template>
                            <Text text="{TabModel>shift}" />
                        </t:template>
                    </t:Column>                   

                   <t:Column tooltip="AIS Shift" width="auto">
                        <Label text="AIS Shift" />
                        <t:template>
                            <Text text="{TabModel>aisshift}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Box No." width="auto">
                        <Label text="Box No." />
                        <t:template>
                            <Text text="{TabModel>boxno}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Quantity Litre" width="auto">
                        <Label text="Quantity Litre" />
                        <t:template>
                            <Text text="{TabModel>qty_l}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Cummulative Qty" width="auto">
                        <Label text="Cummulative Qty" />
                        <t:template>
                            <Text text="{TabModel>cumqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Average Weight" width="auto">
                        <Label text="Average Weight" />
                        <t:template>
                            <Text text="{TabModel>averagewt}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="ATS Weight" width="auto">
                        <Label text="ATS Weight" />
                        <t:template>
                            <Text text="{TabModel>atsweight}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Weight" width="auto">
                        <Label text="Weight" />
                        <t:template>
                            <Text text="{TabModel>weight}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Grade ATS" width="auto">
                        <Label text="Grade ATS" />
                        <t:template>
                            <Text text="{TabModel>gradeats}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Grade AIS" width="auto">
                        <Label text="Grade AIS" />
                        <t:template>
                            <Text text="{TabModel>grageais}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="AIS Wastage" width="auto">
                        <Label text="AIS Wastage" />
                        <t:template>
                            <Text text="{TabModel>aiswastage}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Qty Litre" width="auto">
                        <Label text="Qty Litre" />
                        <t:template>
                            <Text text="{TabModel>qtylitre}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Remarks" width="auto">
                        <Label text="Remarks" />
                        <t:template>
                            <Text text="{TabModel>remarks}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="HFX" width="auto">
                        <Label text="HFX" />
                        <t:template>
                            <Text text="{TabModel>hfx}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Floor Waste" width="auto">
                        <Label text="Floor Waste" />
                        <t:template>
                            <Text text="{TabModel>floorwaste}" />
                        </t:template>
                        </t:Column>

                    <t:Column tooltip="QA Name" width="auto">
                        <Label text="QA Name" />
                        <t:template>
                            <Text text="{TabModel>qaname}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="Operator Name" width="auto">
                    <Label text="Operator Name" />
                    <t:template>
                        <Text text="{TabModel>operatorname}" />
                    </t:template>
                </t:Column>

                <t:Column tooltip="AIS Machine No" width="auto">
                    <Label text="AIS Machine No" />
                    <t:template>
                        <Text text="{TabModel>aismachineno}" />
                    </t:template>
                </t:Column>

                <t:Column tooltip="Status" width="auto">
                    <Label text="Status" />
                    <t:template>
                        <Text text="{TabModel>status}" />
                    </t:template>
                </t:Column>

                <t:Column tooltip="Item Status" width="auto">
                    <Label text="Item Status" />
                    <t:template>
                        <Text text="{TabModel>itemstatus}" />
                    </t:template>
                </t:Column>

                </t:columns>
                
            </t:Table>
        </f:content>
        <!-- DynamicPage Footer -->
    </f:DynamicPage>


</mvc:View>
