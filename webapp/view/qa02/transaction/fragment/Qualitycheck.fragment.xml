                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L2"/>
                            <t:template>
                                <Input  value="{JModel3>l2_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L3"/>
                            <t:template>
                                <Input  value="{JModel3>l3_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L4"/>
                            <t:template>
                                <Input  value="{JModel3>l4_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>

                </t:columns>

            </t:Table>

            <FlexBox direction="Row" alignItems="Center" class="sapUiTinyMarginTop" renderType="Bare">
                <Text text="Critical Total." width="11rem" class="sapUiTinyMarginBegin"/>
                <Input value="{QAJModelInput>/Samples/l1_grade}" width="10rem" editable="false" class="sapUiTinyMarginBegin"/>
                <Input value="{QAJModelInput>/Samples/l2_grade}" width="10rem" editable="false" class="sapUiTinyMarginBegin"/>
                <Input value="{QAJModelInput>/Samples/l3_grade}" width="10rem" editable="false" class="sapUiTinyMarginBegin"/>
                <Input value="{QAJModelInput>/Samples/l4_grade}" width="10rem" editable="false" class="sapUiTinyMarginBegin"/>
            </FlexBox>

        <!-- End Table create place -->
        <VBox class="sapUiSmallMarginTop">
            <Title text="Section2-placehlder for now" level="H3" class="sapUiTinyMarginBottom"/>
                <FlexBox direction="Row" alignItems="Center" class="sapUiSmallMarginTop">
                    <Label text="Field Name:" labelFor="section2Input" width="150px"/>
                    <Input id="section2Input" placeholder="Enter value..." width="300px"/>
                </FlexBox>
        </VBox>

        <VBox class="sapUiTinyMarginTop">
            <Title text="2. CFM Performance	" level="H3" class="sapUiTinyMarginBottom"/>

            <!-- Avg. Wt. of 100 Capsules -->
            <FlexBox direction="Row" alignItems="Center" class="sapUiTinyMarginTop">
                <Label text="Size 0, 480 Capsules" width="150px"/>
                <Input value="{QAJModelInput>/Samples/qa01_cfmperform}" maxLength="120" placeholder="Enter value..."/>

                <Label text="3. Avg. Wt. of 100 Capsules (By Packing):" width="150px"/>
                <Input value="{QAJModelInput>/Samples/qa01_avgwt}" maxLength="120" placeholder="Enter value..."/>
            </FlexBox>

            <!-- Moisture Content (%) -->
            <FlexBox direction="Row" alignItems="Center" class="sapUiSmallMarginTop">
                <Label text="4. Moisture Content (%) (By IPQC):" width="150px"/>
                <Input value="{QAJModelInput>/Samples/qa01_moistcontent}" maxLength="120" placeholder="Enter value..."/>
            </FlexBox>

            <!-- Pull Test -->
            <FlexBox direction="Row" alignItems="Center" class="sapUiSmallMarginTop">
                <Label text="5. Pull Test: (OK / Not OK) (By IPQC):" width="150px"/>
                <Input value="{QAJModelInput>/Samples/qa01_pulltest}" maxLength="120" placeholder="Enter value..."/>
            </FlexBox>

            <!-- Joining Length -->
            <FlexBox direction="Row" alignItems="Center" class="sapUiSmallMarginTop">
                <Label text="6. Joining Length (mm) (By IPQC):" width="150px"/>
                <Input value="{QAJModelInput>/Samples/qa01_joinlength}" maxLength="120" placeholder="Enter value..."/>
            </FlexBox>
        </VBox>




    </VBox>
 
<!-- Start - Footer  -->
        <footer>
            <OverflowToolbar>
                <Button id="messagePopoverBtn" icon="sap-icon://warning2" text="{ErrorModel>/Errors/0/text}" type="Attention" press="onMessageButtonPress" visible="false" />
                <ToolbarSpacer />
                <Button visible="{BtnBasedModel>/Samples/save_btn}" press="onQualitySubmit" icon="sap-icon://save" text="Submit"/>
                <Button visible="{BtnBasedModel>/Samples/update_btn}" press="onQualityUpdate" icon="sap-icon://save" text="Update"/>
                <Button press="onQualityCancel" icon="sap-icon://cancel" text="Cancel"/>


            </OverflowToolbar>
        </footer>
<!-- End - Footer  -->
 
</Dialog>
 
 
