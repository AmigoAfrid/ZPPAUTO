<core1:FragmentDefinition xmlns="sap.m"
 xmlns:core1="sap.ui.core"
  xmlns:mvc="sap.ui.core.mvc"
   xmlns:u="sap.ui.unified"
    xmlns:t="sap.ui.table"
    xmlns:m="sap.f"
    xmlns:layout1="sap.ui.layout"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
 
<Dialog id="id_qualitycheckqa02" title="FINAL QUALITY CHECK ASSESSMENT - PRINTED CAPSULES - FCQ(QA02) ASSESSMENT" showHeader="true"  contentHeight="100%" contentWidth="100%" resizable="true" draggable="true" >
 
    <VBox class="sapUiSmallMargin">
        <!-- Coding Place -->
        <!-- Start Table create place -->
        <Title text="Visual Defects" level="H3" class="sapUiTinyMarginBottom"/>

        <t:Table
            id="id_table1"
            rows="{JModel1>/critical}" rowActionCount="0"
            selectionMode="None"
            rowMode="Fixed"
            >
            <!-- visibleRowCount="{= ${JModel1>/critical}.length }"  -->
                <t:extension>
                    <OverflowToolbar 
                    style="Clear">
                        <Title text="Critical Table"/>
                    </OverflowToolbar>
                </t:extension>

                <t:columns>
                    <t:Column
                    width="4rem"
                    hAlign="Left">
                        <Label text="S.No."/>
                            <t:template>
                                <Text text="{JModel1>sno}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="11rem"
                    hAlign="Left">
                        <Label text="Critical Defects"/>
                            <t:template>
                                <Text text="{JModel1>defects}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="5rem"
                    hAlign="Left">
                        <Label text="Norm"/>
                            <t:template>
                                 <Text 
                                    text="{JModel1>norm}" 
                                    width="100%"
                                    type="Number" 
                                    
                                    />
                                    <!-- placeholder=""
                                    editable="{JModel1>editable}" -->
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level1"/>
                            <t:template>
                                <Input 
                                    value="{JModel1>level1}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel1>l1_status} === '' ? true : false}"

                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level2"/>
                            <t:template>
                                <Input 
                                    value="{JModel1>level2}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder="" 
                                    editable="{= ${JModel1>l2_status} === '' ? true : false}"

                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level3"/>
                            <t:template>
                                <Input 
                                    value="{JModel1>level3}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel1>l3_status} === '' ? true : false}"

                                    change=".onLevelLiveChange" />
                            </t:template>
                    </t:Column>

                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level4"/>
                            <t:template>
                                <Input 
                                    value="{JModel1>level4}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel1>l4_status} === '' ? true : false}"
                                    change=".onLevelLiveChange" />
                            </t:template>
                    </t:Column>

                    <t:Column width="0" hAlign="Left">
                        <Label text="ID"/>
                            <t:template>
                                <Input  value="{JModel1>id}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>

                                                                                
                    <t:Column width="0" hAlign="Left">
                        <Label text="L1"/>
                            <t:template>
                                <Input  value="{JModel1>l1_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L2"/>
                            <t:template>
                                <Input  value="{JModel1>l2_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L3"/>
                            <t:template>
                                <Input  value="{JModel1>l3_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L4"/>
                            <t:template>
                                <Input  value="{JModel1>l4_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>

                </t:columns>

            </t:Table>


            <t:Table
            id="id_table2"
            rows="{JModel2>/major}"
            selectionMode="None"
            rowMode="fixed"
            class="sapUiMediumMarginTop sapUiSmallMarginBottom">
            
                <t:extension>
                    <OverflowToolbar 
                    style="Clear">
                        <Title text="Major Table"/>
                    </OverflowToolbar>
                </t:extension>

                <t:columns>
                    <t:Column
                    width="4rem"
                    hAlign="Left">
                        <Label text="S.No."/>
                            <t:template>
                                <Text text="{JModel2>sno}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="11rem"
                    hAlign="Left">
                        <Label text="Major Defects"/>
                            <t:template>
                                <Text text="{JModel2>defects}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="5rem"
                    hAlign="Left">
                        <Label text="Norm"/>
                            <t:template>
                                <Text 
                                    text="{JModel2>norm}" 
                                    width="100%"
                                    

                                    />
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level1"/>
                            <t:template>
                                <Input 
                                    value="{JModel2>level1}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel2>l1_status} === '' ? true : false}"
                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level2"/>
                            <t:template>
                                <Input 
                                    value="{JModel2>level2}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel2>l2_status} === '' ? true : false}"
                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level3"/>
                            <t:template>
                                <Input 
                                    value="{JModel2>level3}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel2>l3_status} === '' ? true : false}"
                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level4"/>
                            <t:template>
                                <Input 
                                    value="{JModel2>level4}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel2>l4_status} === '' ? true : false}"
                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                    
                    <t:Column width="0" hAlign="Left">
                        <Label text="ID"/>
                            <t:template>
                                <Input  value="{JModel2>id}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                                            
                    <t:Column width="0" hAlign="Left">
                        <Label text="L1"/>
                            <t:template>
                                <Input  value="{JModel2>l1_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L2"/>
                            <t:template>
                                <Input  value="{JModel2>l2_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L3"/>
                            <t:template>
                                <Input  value="{JModel2>l3_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>
                                        
                    <t:Column width="0" hAlign="Left">
                        <Label text="L4"/>
                            <t:template>
                                <Input  value="{JModel2>l4_status}"  width="100%" type="Text"  placeholder="" />
                            </t:template>
                    </t:Column>


                </t:columns>


            </t:Table>




            <t:Table
             id="id_table3"
             rows="{JModel3>/minor}"
             selectionMode="None"
             rowMode="fixed"
             class="sapUiTinyMarginTop sapUiSmallMarginBottom">
            
                <t:extension>
                    <OverflowToolbar 
                    style="Clear">
                        <Title text="Minor Table"/>
                    </OverflowToolbar>
                </t:extension>

                <t:columns>
                    <t:Column
                    width="4rem"
                    hAlign="Left">
                        <Label text="S.No."/>
                            <t:template>
                                <Text text="{JModel3>sno}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="11rem"
                    hAlign="Left">
                        <Label text="Minor Defects"/>
                            <t:template>
                                <Text text="{JModel3>defects}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="5rem"
                    hAlign="Left">
                        <Label text="Norm"/>
                            <t:template>
                                <Text 
                                    text="{JModel3>norm}" 
                                    width="100%"
                                    type="Number" 
                                   />
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level1"/>
                            <t:template>
                                <Input 
                                    value="{JModel3>level1}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel3>l1_status} === '' ? true : false}"
                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
