                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel3>l2_status} === '' ? true : false}"
                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="Level3"/>
                            <t:template>
                                <Input 
                                    value="{JModel3>level3}" 
