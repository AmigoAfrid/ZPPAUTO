                        <Label text="Level4"/>
                            <t:template>
                                <Input 
                                    value="{JModel3>level4}" 
                                    width="100%"
                                    type="Text" 
                                    placeholder=""
                                    editable="{= ${JModel3>l4_status} === '' ? true : false}"
                                    change=".onLevelLiveChange"/>
                            </t:template>
                    </t:Column>
                                                                                
                    <t:Column width="0" hAlign="Left">
