                                        suggest=".OnSuggest_User_Batch" suggestionItems="{path: 'ZCE_ZCOUNT_HEAD_SRVB>/ZCE_ZCOUNT_BATCH_F4HELP',sorter: { path: 'batch' }}" 
                                        showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_Batch">
                                        <suggestionItems>
                                            <core:Item key="{ZCE_ZCOUNT_HEAD_SRVB>batch}" />
                                        </suggestionItems>
                                    
                                    </MultiInput>


                                   
                                <layout:HorizontalLayout class=" sapUiLargeMarginBegin ">
                                    
                                    <layout:HorizontalLayout class=" sapUiLargeMarginBegin "></layout:HorizontalLayout >


                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" />
                                    </layout:HorizontalLayout>

                                </layout:VerticalLayout>		

                                <layout:VerticalLayout visible="false" class="sapUiSmallMarginBegin ">

                                    <Label text="Plant No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
