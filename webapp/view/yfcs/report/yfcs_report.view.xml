                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Process Ord No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="IdProcessOrder" placeholder="Select Process Ord No." editable="true" enabled="true"   
                                                showValueHelp="true" valueHelpRequest=".onValueHelpRequestProcOrder"  suggest=".OnSuggest_User_ProcOrder" 
                                                suggestionItems="{path: 'ZSB_AU_FT_HEADER>/ZC_AU_FT_HEADER',sorter: { path: 'Prodorderno' }}" 
                                                showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_ProcOrder">
                                            <suggestionItems>
                                                <core:Item key="{ZSB_AU_FT_HEADER>ProdDoc}"></core:Item>
                                            </suggestionItems>
                                    </MultiInput>
                                   
                                </layout:VerticalLayout> -->

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table
                id="idYfcsTable"
                rows="{path:'TabModel>/ItemData', sorter: { path: 'sno', descending: false }}"
                selectionMode="MultiToggle"
                selectionBehavior="RowSelector"
                fixedColumnCount="6"
                enableSelectAll="true"
                rowMode="Auto"
                enableBusyIndicator="true"
                threshold="100"
                rowSelectionChange=".onRowSelectionChange">


                
                   <t:extension>
						<OverflowToolbar  style="Clear">
							<ToolbarSpacer/>
							<ToolbarSpacer/>
                   			 <Button  icon="sap-icon://excel-attachment" press="OnExportExl"/>
						</OverflowToolbar>
					</t:extension>

                <t:columns>
				
                    <!-- <t:Column tooltip="Report Id" width="7rem">
                        <Label text="Report Id" />
                        <t:template>
                            <Text text="{path:'TabModel>report_id'}" />
                        </t:template>
                    </t:Column> -->

                    <!-- <t:Column tooltip="Date" width="7rem">
                        <Label text="Date" />
                        <t:template>
                            <Text text="{path:'TabModel>createdat'}" />
                        </t:template>
                    </t:Column> -->
                    <t:Column tooltip="Date" width="7rem">
                        <Label text="Date" />
                        <t:template>
                            <DatePicker value="{path: 'TabModel>createdat',type: 'sap.ui.model.type.Date',formatOptions: {pattern: 'dd-MM-yyyy'}}" editable="false" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Customer Name" width="10rem">
                        <Label text="Customer Name" />
                        <t:template>
                            <Text text="{TabModel>customername}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Batch" width="7rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{path:'TabModel>batch'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Sales Order" width="7rem">
                        <Label text="Sales Order" />
                        <t:template>
                            <Text text="{path:'TabModel>salesorder'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Material" width="7rem">
                        <Label text="Material" />
                        <t:template>
                            <Text text="{path:'TabModel>material'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Total Lakhs" width="7rem">
                        <Label text="Total Lakhs" />
                        <t:template>
                            <Text text="{path:'TabModel>qty_lac'}" /> 
                            <!-- tot_lac -->
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Plant" width="7rem">
                        <Label text="Plant" />
                        <t:template>
                            <Text text="{path:'TabModel>plant'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Process Order No" width="7rem">
                        <Label text="Process Order No" />
                        <t:template>
                            <Text text="{path:'TabModel>process_order'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Box No" width="7rem">
                        <Label text="Box No" />
                        <t:template>
                            <Text text="{path:'TabModel>boxno'}" />
                        </t:template>
                    </t:Column>


                    <t:Column tooltip="Drum No" width="7rem">
                        <Label text="Drum No" />
                        <t:template>
                            <Text text="{path:'TabModel>drum_no'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Net Weight" width="7rem">
                        <Label text="Net Weight" />
                        <t:template>
                            <Text text="{path:'TabModel>netwt'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Gross Weight" width="7rem">
                        <Label text="Gross Weight" />
                        <t:template>
                            <Text text="{path:'TabModel>grosswt'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Packing Operator" width="7rem">
                        <Label text="Packing Operator" />
                        <t:template>
                            <Text text="{path:'TabModel>packedby'}" />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Cap Printing" width="7rem">
                        <Label text="Cap Printing" />
                        <t:template>
                            <Text text="{TabModel>capprinting}" />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Body Printing" width="7rem">
                        <Label text="Body Printing" />
                        <t:template>
                            <Text text="{TabModel>bodyprinting}" />
                        </t:template> 
                    </t:Column>

                    <t:Column tooltip="FSC Operator" width="7rem">
                        <Label text="FSC Operator" />
                        <t:template>
                            <!-- <Input value="{path:'TabModel>fsc_operator'}" 
                                    editable="{
                                    parts: [
                                        { path: 'TabModel>status' },
                                        { path: 'UserModel>/roles' }],
                                    formatter: '.formatter.isReverseEnabled' }" />                           -->

                            <Input value="{path:'TabModel>fsc_operator'}" editable="{=
                                                ${AdminPanelAuth>/Samples/Role} === true
                                                ? true
                                                : ${TabModel>status} !== 'X'  }" />

                        </t:template>
                    </t:Column>

                    <t:Column tooltip="YFCS Date" width="7rem">
                        <Label text="YFCS Date" />
                        <t:template>
                             <DatePicker value="{path: 'TabModel>yfcs_date',type: 'sap.ui.model.type.Date',formatOptions: {pattern: 'dd-MM-yyyy'}}" 
                                         editable="{=${AdminPanelAuth>/Samples/Role} === true
                                                    ? true
                                                    : ${TabModel>status} !== 'X'
                                                    }"    />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Observations" width="7rem">
                        <Label text="Observations" />
                        <t:template>
                            <Input value="{path:'TabModel>Observations'}" 
                                   editable="{=${AdminPanelAuth>/Samples/Role} === true
                                                    ? true
                                                    : ${TabModel>status} !== 'X'
                                                }"  />
                        </t:template>
                    </t:Column>       

                    <!-- editable="{= ${TabModel>location} ? false : true}"   -->

                    <t:Column tooltip="Location" width="7rem">
                        <Label text="Location" />      
                        <t:template>
                            <Input value="{TabModel>location}"
                                   editable="{=${AdminPanelAuth>/Samples/Role} === true
                                                    ? true
                                                    : ${TabModel>status} !== 'X'
                                                }"      />
                        </t:template>
                    </t:Column>
                </t:columns>    
                <t:footer>
                    <OverflowToolbar style="Clear">
                        <ToolbarSpacer/>
                        <Button text="Update" id="updateId" tooltip="Update" width="6rem" type="Accept" press="onSaveorUpdateSelectedRows" visible="{=${AdminPanelAuth>/Samples/Role} === false ? false : true}"  />
                        <Button text="Save" id="saveId" tooltip="Save" width="6rem" type="Emphasized" press="onSaveorUpdateSelectedRows" icon="sap-icon://save" enabled="{TabModel>saveEnabled}"  visible="{=${AdminPanelAuth>/Samples/Role} === false ? true : false}"  />
                    </OverflowToolbar>
                </t:footer>


            </t:Table>
           
        </f:content>
        
                
    </f:DynamicPage>

</mvc:View>
