<mvc:View
    controllerName="zautodesignapp.controller.yfcs.report.yfcs_report"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

    <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Counting record - YFCS" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>

                        <layout:VerticalLayout >

                            <layout:HorizontalLayout>

                                <layout:VerticalLayout class="sapUiTinyMargin" >
                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false"  />
                                    <DateRangeSelection id="DatesId" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="13rem" value="" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiTinyMargin" >
                                    <Label text="Process Ord No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="IdProcessOrder" placeholder="Select Process Ord No." editable="true" enabled="true"   
                                                showValueHelp="true" valueHelpRequest=".onValueHelpRequestProcOrder"  suggest=".OnSuggest_User_ProcOrder" 
                                                suggestionItems="{path: 'ZSB_AU_FT_HEADER>/ZC_AU_FT_HEADER',sorter: { path: 'Prodorderno' }}" 
                                                showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_ProcOrder">
                                            <suggestionItems>
                                                <core:Item key="{ZSB_AU_FT_HEADER>ProdDoc}"></core:Item>
                                            </suggestionItems>
                                    </MultiInput>
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiTinyMargin " visible="true" >

                                    <Label text="Batch No." design="Bold" visible="true" required="false" labelFor="multiInputWithSuggestions" />
                                    
                                    <MultiInput visible="true" maxLength="10" required="true" width="12.5rem" id="IdBatch" placeholder="Select Batch No." editable="true" enabled="true"   
                                        showValueHelp="true" valueHelpRequest=".onValueHelpRequestBatch"  
                                        suggest=".OnSuggest_User_Batch" suggestionItems="{path: 'ZCE_ZCOUNT_HEAD_SRVB>/ZCDS_BATCH_F4HELP',sorter: { path: 'batch' }}" 
                                        showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_Batch">
                                        <suggestionItems>
                                            <core:Item key="{ZCE_ZCOUNT_HEAD_SRVB>batch}" />
                                        </suggestionItems>
                                    
                                    </MultiInput>
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiTinyMargin"   >

                                    <Label text="Plant No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" width="12.5rem" id="IdPlant" placeholder="Select Plant" editable="true" enabled="true"   
                                                showValueHelp="true" valueHelpRequest=".onValueHelpRequestPlant"  suggest=".OnSuggest_User_Plant" 
                                                suggestionItems="{path: 'ZCE_ZCOUNT_HEAD_SRVB>/ZCE_PLANT_F4HELP',sorter: { path: 'plant' }}" 
                                                showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_Plant">
                                    
                                        <suggestionItems>                                        
                                            <core:Item key="{ZCE_ZCOUNT_HEAD_SRVB>plant}" />                                        
                                        </suggestionItems>
                                        
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>



                            </layout:HorizontalLayout>

                                <layout:HorizontalLayout>
                                    <Label width="25rem" />
                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" class="sapUiTinyMargin" /> 
                                </layout:HorizontalLayout>

                        </layout:VerticalLayout>

<!-- 
								<layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false"  />
                                    <DateRangeSelection id="DatesId" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value="" />

                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Batch No." design="Bold" visible="false" required="false" labelFor="multiInputWithSuggestions"/>
                                    
