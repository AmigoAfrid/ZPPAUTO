<mvc:View
    controllerName="zautodesignapp.controller.ftp.report.ftp_report"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

    <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="FTP Report" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
								<layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false" class="sapUiSmallMarginBegin" />
                                    <DateRangeSelection id="Date" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value="" />

                                </layout:VerticalLayout>



                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Batch No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>

                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialdocument" placeholder="Select Batch No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest"  suggest=".OnSuggest_User" suggestionItems="{
                                        path: 'ZNC_FT_HD_ITEM_REPORT_SRVB>/ZNC_FT_HEADER_ITEM',
                                        sorter: { path: 'Acmbatchno' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected">
                                    <suggestionItems>

                                    <core:Item key="{ZNC_FT_HD_ITEM_REPORT_SRVB>Acmbatchno}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>

                                    <layout:HorizontalLayout class=" sapUiLargeMarginBegin "><layout:HorizontalLayout class=" sapUiLargeMarginBegin "></layout:HorizontalLayout>


                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" /></layout:HorizontalLayout>

                                </layout:VerticalLayout>		

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Production Ord No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="ProdDoc" placeholder="Select Production Ord No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest_"  suggest=".OnSuggest_User_" suggestionItems="{
                                    path: 'ZNC_FT_HD_ITEM_REPORT_SRVB>/ZNC_FT_HEADER_ITEM',
                                    sorter: { path: 'Prodorderno' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_">
                                    
                                    <suggestionItems>
                                    
                                    <core:Item key="{ZNC_FT_HD_ITEM_REPORT_SRVB>Prodorderno}"></core:Item>
                                    
                                    </suggestionItems>
                                    
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Plant No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idPlantInput" placeholder="Select Plant" editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestPlant"  suggest=".OnSuggest_UserPlant" suggestionItems="{
                                    path: 'ZNC_FT_HD_ITEM_REPORT_SRVB>/ZNC_FT_HEADER_ITEM',
                                    sorter: { path: 'Plant' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedPlant">
                                    
                                    <suggestionItems>
                                    
                                    <core:Item key="{ZNC_FT_HD_ITEM_REPORT_SRVB>Plant}"></core:Item>
                                    
                                    </suggestionItems>
                                    
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>


                                 <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Material:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>                                   
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterial" placeholder="Select Material" editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestMaterial"  suggest=".OnSuggest_Usermaterial" suggestionItems="{
                                    path: 'ZAU_FT_PROCESSORDER_SRVB_>/ZCDS_COMPONENT_F4HELP',
                                    sorter: { path: 'Material' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedMaterial">                        
                                    <suggestionItems>                                    
                                        <core:Item key="{ZAU_FT_PROCESSORDER_SRVB_>Material}" text="{ZAU_FT_PROCESSORDER_SRVB_>Material}"></core:Item>                                    
                                    </suggestionItems>
                                    
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>

            <t:Table
                rows="{path:'TabModel>/ItemData', sorter: {path: 'TabModel>item1'}}"
                id="ft_report_table"
                selectionMode="None"
                enableSelectAll="false"
                rowMode="Auto" fixedColumnCount="4" >

                       <t:extension>
						<OverflowToolbar  style="Clear">
							<ToolbarSpacer/>
							<ToolbarSpacer/>
                   			 <Button id="_IDGenButtonftscreen" icon="sap-icon://excel-attachment" press="OnExportExl"/>
						</OverflowToolbar>
					</t:extension>

                <t:columns>
				
                    <t:Column tooltip="Date" width="6rem">
                        <Label text="Date" />
                        <t:template>
                            <Text text="{path:'TabModel>entrydate',formatter: '.OnDateChangeValue'}" />
                        </t:template>
                    </t:Column>


                       <t:Column tooltip="Shift" width="3rem">
                        <Label text="Shift" />
                        <t:template>
                            <Text text="{TabModel>Shift}" />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Feed Tank No" width="6.5rem">
                        <Label text="Feed Tank No" />
                        <t:template>
                            <Text text="{TabModel>Ftno}" />
                        </t:template>
                    </t:Column>

                    
                    <t:Column tooltip="Batch No" width="6rem">
                        <Label text="Batch No" />
                        <t:template>
                            <Text text="{path:'TabModel>Acmbatchno',formatter:'.removeLeadingZeros'}" />
                        </t:template>
                    </t:Column>

                    <t:Column  visible="false" tooltip="Plant" width="8rem">
                        <Label text="Plant" />
                        <t:template>
                            <Text text="{TabModel>Plant}" />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Production Ord No" width="8.5rem">
                        <Label text="Production Ord No" />
                        <t:template>
                            <Text text="{TabModel>Prodorderno}" />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Ord Qty" width="5rem">
                        <Label text="Ord Qty" />
                        <t:template>
                            <Text text="{TabModel>Ftqty}" />
                        </t:template>
                    </t:Column>


                        <t:Column tooltip="Material" width="5rem">
                        <Label text="Material" />
                        <t:template>
                            <Text text="{TabModel>Product}" />
                        </t:template>
                    </t:Column>

                        
                    <t:Column tooltip="Item Code " width="6rem">
                        <Label text="Item Code" />
                        <t:template>
                            <Text text="{TabModel>Matnr}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Item Description" width="14rem">
                        <Label text="Item Description" />
                        <t:template>
                            <Text text="{TabModel>Maktx}" />
                        </t:template>
                    </t:Column> 

                      <t:Column tooltip="Qty In Kgs" width="6.5rem">
                        <Label text="Qty In Kgs" />
                        <t:template>
                            <Text text="{TabModel>Qty}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Unit" width="4.5rem">
                        <Label text="Unit" />
                        <t:template>
                            <Text text="{TabModel>Unit}" />
                        </t:template>
                    </t:Column>


                         <t:Column tooltip="Chemist" width="5rem">
                        <Label text="Chemist" />
                        <t:template>
                            <Text text="{TabModel>Chemist}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="QA" width="5rem">
                        <Label text="QA" />
                        <t:template>
                            <Text text="{TabModel>Qa}" />
                        </t:template>
                    </t:Column>


                    <t:Column visible="false" tooltip="Goods Issue" width="8rem">
                        <Label text="Goods Issue" />
                        <t:template>
                            <Text text="{TabModel>GoodsIssue}" />
                        </t:template>
                    </t:Column>

                    <t:Column visible="false" tooltip="Goods Receipt" width="8rem">
                        <Label text="Goods Receipt" />
                        <t:template>
                            <Text text="{TabModel>GoodsReceipt}" />
                        </t:template>
                    </t:Column>

                </t:columns>

            </t:Table>
        </f:content>
        <!-- DynamicPage Footer -->
    </f:DynamicPage>

</mvc:View>
