    height="100%">

        <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Wastage Report" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
                                <layout:VerticalLayout visible="true" class=" ">

                                <layout:HorizontalLayout visible="true" class=" sapUiSmallMarginEnd  customWidth">
                                    <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false" class="myCustomVBoxClassSpacingS " />
                                    <!-- <DatePicker  id="Dates" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="11.5rem" /> -->
                                    <DateRangeSelection id="Dates" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value=""  class=" sapUiSmallMarginBegin" required="false"/>
                                    </layout:VerticalLayout>

                                    <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Batch No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="9.5rem" id="idmaterialdocument" placeholder="Select Batch No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest"  suggest=".OnSuggest_User" suggestionItems="{
                                        path: 'ZCE_ZCOUNT_HEAD_SRVB>/ZCE_ZCOUNT_BATCH_F4HELP',
                                        sorter: { path: 'batch' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected">
                                    <suggestionItems>

                                    <core:Item key="{ZCE_ZCOUNT_HEAD_SRVB>batch}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>
								<layout:VerticalLayout visible="true" class="myCustomVBoxClassH myCustomVBoxClass">
									<Label text="Select Wastage Print :" tooltip="Radio Button" design="Bold" required="false"  class="myCustomVBoxClassSpacing"/>
									<RadioButtonGroup id="rbg3" columns="5"  class="sapUiMediumMarginBottom" select="onRadioSelect" >
										<RadioButton id="RB3-1" text="ATS" />
										<RadioButton id="RB3-2" text="AIS" />
										<RadioButton id="RB3-3" text="PTG" />
									</RadioButtonGroup>
								</layout:VerticalLayout>

                                    </layout:VerticalLayout>

                                    </layout:HorizontalLayout>    


                                <layout:HorizontalLayout class="myCustomVBoxClassH sapUiLargeMarginBegin ">


                                    <Button text="Print" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" class="myCustomVBoxClassGo myCustomVBoxClassGo"/></layout:HorizontalLayout>
                                    
                                </layout:VerticalLayout>	
                            
                            <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">
                            </layout:VerticalLayout>	

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

