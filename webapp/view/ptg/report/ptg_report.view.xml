<mvc:View
    controllerName="zautodesignapp.controller.ptg.report.ptg_report"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

    <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="PTG Report" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
								<layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false" class="sapUiSmallMarginBegin" />
                                    <DateRangeSelection id="Date" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value="" />

                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Batch No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialdocument" placeholder="Select Batch No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest"  suggest=".OnSuggest_User" suggestionItems="{
                                        path: 'ZSB_PTG_REPORT/ZPTG_REPORT',
                                        sorter: { path: 'batch' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected">
                                    <suggestionItems>

                                    <core:Item key="{ZSB_PTG_REPORT>batch}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>

                                    <layout:HorizontalLayout class=" sapUiLargeMarginBegin "><layout:HorizontalLayout class=" sapUiLargeMarginBegin "></layout:HorizontalLayout>


                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" /></layout:HorizontalLayout>

                                </layout:VerticalLayout>	
                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Process Ord No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idprocessorder" placeholder="Select Process Ord No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest_"  suggest=".OnSuggest_User_" suggestionItems="{
                                        path: 'ZSB_PTG_REPORT/ZPTG_REPORT',
                                        sorter: { path: 'processorder' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_">
                                    <suggestionItems>

                                    <core:Item key="{ZSB_PTG_REPORT>processorder}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>
                                </layout:VerticalLayout>


                                                       <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Material:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>                                   
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialptg" placeholder="Select Material" editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestMaterial"  suggest=".OnSuggest_Usermaterial" suggestionItems="{
                                    path: 'ZCE_ZCOUNT_HEAD_SRVB>/ZCE_PRODUCT_F4HELP',
                                    sorter: { path: 'Product' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedMaterial">                        
                                    <suggestionItems>
                                    
                                    <core:Item key="{ZCE_ZCOUNT_HEAD_SRVB>Product}"></core:Item>
                                    
                                    </suggestionItems>
                                    
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>


                                <layout:VerticalLayout  class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth" >
									<Label tooltip="Select Machine No"  required="true"  text="Select Machine No" design="Bold" />
								   <Input 
                                         
                                            type="Text"
											 id="id_PTGmachines"
                                            editable="true"
                                            showValueHelp="true"
                                            value="{ptgModel>/HeaderData/0/selectedMachine}"
                                            valueHelpIconSrc="sap-icon://value-help"
                                            valueHelpRequest="OnPTGCheck"/>
								</layout:VerticalLayout>
                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table
                rows="{path:'TabModel>/ItemData', sorter: {path: 'TabModel>item1'}}"
                selectionMode="None"
                id = "PTG_report_table"
                enableSelectAll="false"
                rowMode="Auto" fixedColumnCount="5" >

                   <t:extension>
						<OverflowToolbar  style="Clear">
							<ToolbarSpacer/>
							<ToolbarSpacer/>
                   			 <Button id="_IDGenButtonPTGscreen" icon="sap-icon://excel-attachment" press="OnExportExl"/>
						</OverflowToolbar>
					</t:extension>
                <t:columns>
				
                <t:Column tooltip="Date" width="6rem">
                    <Label text="Date" />
                    <t:template>
                        <Text text="{path:'TabModel>zdate',formatter: '.formatDate'}" />
                    </t:template>
                </t:Column>


                <t:Column tooltip="Shift" width="5rem">
                        <Label text="Shift" />
                        <t:template>
                            <Text text="{TabModel>shift}" />
                        </t:template>
                    </t:Column>
 
 
                <t:Column tooltip="PTG Machine No" width="7.5rem">
                        <Label text="PTG Machine No" />
                        <t:template>
                            <Text text="{TabModel>ptgmachneno}" />
                        </t:template>
                    </t:Column>


                     <t:Column tooltip="Customer Name" width="6rem">
                        <Label text="Customer Name" />
                        <t:template>
                            <Text text="{TabModel>customername}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Batch" width="6rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{TabModel>batch}" />
                        </t:template>
                    </t:Column>

     
                    <t:Column tooltip="Material" width="8rem">
                        <Label text="Material" />
                        <t:template>
                            <Text text="{TabModel>product}" />
                        </t:template>
                    </t:Column>

    

                    <t:Column tooltip="Material Description" width="8rem">
                        <Label text="Material Description" />
                        <t:template>
                            <Text text="{TabModel>productdescription}" />
                        </t:template>
                    </t:Column>


                    
                    <t:Column tooltip="Size" width="6rem">
                        <Label text="Size" />
                        <t:template>
                            <Text text="{TabModel>zsize}" />
                        </t:template>
                    </t:Column>


                     <t:Column tooltip="Box No" width="5rem">
                        <Label text="Box No" />
                        <t:template>
                            <Text text="{TabModel>boxno}" />
                        </t:template>
                    </t:Column>


                      <t:Column tooltip="AIS Weight" width="8rem">
                        <Label text="AIS Weight" />
                        <t:template>
                            <Text text="{TabModel>aisweight}" />
                        </t:template>
                    </t:Column>


                     <t:Column tooltip="PTG Weight" width="6rem">
                        <Label text="PTG Weight" />
                        <t:template>
                            <Text text="{TabModel>ptgweight}" />
                        </t:template>
                    </t:Column>


                      <t:Column tooltip="Process Order" width="6rem">
                        <Label text="Process Order" />
                        <t:template>
                            <Text text="{TabModel>processorder}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="QTY Lakhs" width="6rem">
						<Label text="QTY Lakhs" />
						<t:template>
								<Text text="{TabModel>qtylitre}" />
						</t:template>
					</t:Column>

                    
                <t:Column tooltip="PTG Waste in KGS" width="9rem">
                        <Label text="PTG Waste in KGS" />
                        <t:template>
                            <Text text="{TabModel>ptgwaste}" />
                        </t:template>
                    </t:Column>



                      <t:Column tooltip="PTG Waste in Lakhs" width="9rem">
                        <Label text="PTG Waste in Lakhs" />
                        <t:template>
                            <Text text="{TabModel>ptgwastageinlac}" />
                        </t:template>
                    </t:Column>

                          
                <t:Column tooltip="PTG Grade" width="6rem">
                        <Label text="PTG Grade" />
                        <t:template>
                            <Text text="{TabModel>grageptg}" />
                        </t:template>
                    </t:Column>
                    
                    <t:Column tooltip="Material Document No" width="12rem">
                        <Label text="Material Document No 261" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno}" />
                        </t:template>
                    </t:Column>


                      <t:Column tooltip="Material Document No" width="12rem">
                        <Label text="Material Document No 531" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno_gi531}" />
                        </t:template>
                    </t:Column>

                    
                      <t:Column tooltip="Material Document No" width="14rem">
                        <Label text="Material Document Goods Receipt" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno_gr}" />
                        </t:template>
                    </t:Column>


                <t:Column tooltip="AIS Shift" width="5rem">
                    <Label text="AIS Shift" />
                    <t:template>
                        <Text text="{TabModel>aisshift}" />
                    </t:template>
                </t:Column>

                <t:Column tooltip="PTG Shift" width="5rem">
                        <Label text="PTG Shift" />
                        <t:template>
                            <Text text="{TabModel>ptgshift}" />
                        </t:template>
                    </t:Column>
                
   
                <t:Column tooltip="Avg Weight" width="8rem">
                        <Label text="Avg Weight" />
                        <t:template>
                            <Text text="{TabModel>avgweight}" />
                        </t:template>
                    </t:Column>


                <t:Column tooltip="Weight" width="6rem">
                        <Label text="Weight" />
                        <t:template>
                            <Text text="{TabModel>weight}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="AIS Cumulative Qty" width="10rem">
                        <Label text="AIS Cumulative Qty" />
                        <t:template>
                            <Text text="{TabModel>aiscumulativeqty}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="Cumulative Qty" width="8rem">
                        <Label text="Cumulative Qty" />
                        <t:template>
                            <Text text="{TabModel>cumulativeqty}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="Cumulative Grade" width="8rem">
                        <Label text="Cumulative Grade" />
                        <t:template>
                            <Text text="{TabModel>cumulativeagrade}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="A Garde Weight" width="8rem">
                        <Label text="A Garde Weight" />
                        <t:template>
                            <Text text="{TabModel>agradeweight}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="Grade AIS" width="6rem">
                        <Label text="Grade AIS" />
                        <t:template>
                            <Text text="{TabModel>gradeais}" />
                        </t:template>
                    </t:Column>
                
                <t:Column tooltip="Grade ATS" width="6rem">
                        <Label text="Grade ATS" />
                        <t:template>
                            <Text text="{TabModel>gradeats}" />
                        </t:template>
                    </t:Column>

       
                <t:Column tooltip="Cummulative Entry" width="7.5rem">
                        <Label text="Cummulative Entry" />
                        <t:template>
                            <Text text="{TabModel>cummulativeentry}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="Remarks" width="6rem">
                        <Label text="Remarks" />
                        <t:template>
                            <Text text="{TabModel>remarks}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="HFX" width="6rem">
                        <Label text="HFX" />
                        <t:template>
                            <Text text="{TabModel>hfx}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="Floor Wastage" width="6rem">
                        <Label text="Floor Wastage" />
                        <t:template>
                            <Text text="{TabModel>floorwastage}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="QA Name" width="6rem">
                        <Label text="QA Name" />
                        <t:template>
                            <Text text="{TabModel>qaname}" />
                        </t:template>
                    </t:Column>

            

                <t:Column tooltip="Operator Name" width="6rem">
                        <Label text="Operator Name" />
                        <t:template>
                            <Text text="{TabModel>operatorname}" />
                        </t:template>
                    </t:Column>



                       <t:Column tooltip="Cap Text" width="10rem">
                        <Label text="CAP Text" />
                        <t:template>
                            <Text text="{TabModel>captext}" />
                        </t:template>
                    </t:Column>


                       <t:Column tooltip="Body Text" width="10rem">
                        <Label text="Body Text" />
                        <t:template>
                            <Text text="{TabModel>bodytext}" />
                        </t:template>
                    </t:Column>


                       <t:Column tooltip="CAP Ink" width="10rem">
                        <Label text="CAP INK" />
                        <t:template>
                            <Text text="{TabModel>capink}" />
                        </t:template>
                    </t:Column>



                      <t:Column tooltip="Body Ink" width="10rem">
                        <Label text="Body INK" />
                        <t:template>
                            <Text text="{TabModel>bodyink}" />
                        </t:template>
                    </t:Column>


                       <t:Column tooltip="Print Roller No" width="6rem">
                        <Label text="Print Roller No" />
                        <t:template>
                            <Text text="{TabModel>printinrollerno}" />
                        </t:template>
                    </t:Column>


        


                <t:Column  visible="false" tooltip="Item Status" width="6rem">
                        <Label text="Item Status" />
                        <t:template>
                            <Text text="{TabModel>itemstatus}" />
                        </t:template>
                    </t:Column>

                <t:Column visible="false"  tooltip="Screen Code" width="6rem">
                        <Label text="Screen Code" />
                        <t:template>
                            <Text text="{TabModel>screencode}" />
                        </t:template>
                    </t:Column>

            </t:columns>

            </t:Table>
        </f:content>
        <!-- DynamicPage Footer -->
    </f:DynamicPage>


</mvc:View>
