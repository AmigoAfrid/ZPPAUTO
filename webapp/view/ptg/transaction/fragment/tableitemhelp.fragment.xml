<core1:FragmentDefinition 
    xmlns="sap.m"
    xmlns:core1="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:u="sap.ui.unified"
    xmlns:t="sap.ui.table"
    xmlns:m="sap.f"
    xmlns:layout1="sap.ui.layout"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core">

    <Dialog  id="tableitptg"  title="PTG Table item"  showHeader="true"  verticalScrolling="true"  horizontalScrolling="true"  contentHeight="50%"  contentWidth="100%"  resizable="true"  draggable="true">

        <VBox class="sapUiSmallMargin">
            <!-- Start Table create place -->
            <t:Table rows="{CompDipsModel>/Datatabitem}" selectionMode="None" rowMode="fixed">
                
                <t:extension>
                    <OverflowToolbar style="Clear">
                        <Title text="Component Item Table"/>
                    </OverflowToolbar>
                </t:extension>
                
                <t:columns>
                    <t:Column width="12rem" hAlign="Left">
                        <Label text="Material"/>
                        <t:template>
                            <Text text="{CompDipsModel>material}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="14rem" hAlign="Left">
                        <Label text="Description"/>
                        <t:template>
                            <Text text="{CompDipsModel>materialdescription}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="10rem" hAlign="Left">
                        <Label text="Quantity"/>
                        <t:template>
                            <Text text="{CompDipsModel>quantity}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="5rem" hAlign="Left">
                        <Label text="Base Unit"/>
                        <t:template>
                            <Text text="{CompDipsModel>base_unit}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="5rem" hAlign="Left">
                        <Label text="Plant"/>
                        <t:template>
                            <Text text="{CompDipsModel>plant}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="10rem" hAlign="Left">
                        <Label text="Storage Location"/>
                        <t:template>
                            <Text text="{CompDipsModel>storage_location}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="11rem" hAlign="Left">
                        <Label text="Batch"/>
                        <t:template>
                            <!-- <Text text="{CompDipsModel>batch}"/> -->
                             <Input value="{CompDipsModel>batch}" showValueHelp="true"  valueHelpRequest=".onValueHelpRequestBatch" />
                        </t:template>
                    </t:Column>

                    <t:Column width="9rem" hAlign="Left">
                        <Label text="Movement Type"/>
                        <t:template>
                            <!-- <Text text="{CompDipsModel>movement_type}"/> -->
                            <tnt:InfoLabel text="{CompDipsModel>movement_type}" renderMode="Narrow" colorScheme="{= ${CompDipsModel>movement_type} === '261' ? 8 : 1 }"/>
                        </t:template>
                    </t:Column>

                    <!-- <t:Column width="auto" hAlign="Left">
                        <Label text="Cap Cut QTY(KG)"/>
                        <t:template>
                            <Text text="{CompDipsModel>cap_cut_qty}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="auto" hAlign="Left">
                        <Label text="Body Cut QTY(KG)"/>
                        <t:template>
                            <Text text="{CompDipsModel>body_cut_qty}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="auto" hAlign="Left">
                        <Label text="Cap Cake QTY(KG)"/>
                        <t:template>
                            <Text text="{CompDipsModel>cap_cake_qty}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="auto" hAlign="Left">
                        <Label text="Body Cake QTY(KG)"/>
                        <t:template>
                            <Text text="{CompDipsModel>body_cake_qty}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="auto" hAlign="Left">
                        <Label text="HFX"/>
                        <t:template>
                            <Text text="{CompDipsModel>hfx}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="auto" hAlign="Left">
                        <Label text="Wastage"/>
                        <t:template>
                            <Text text="{CompDipsModel>wastage}"/>
                        </t:template>
                    </t:Column>

                    <t:Column width="auto" hAlign="Left">
                        <Label text="Floor Wastage"/>
                        <t:template>
                            <Text text="{CompDipsModel>floor_wastage}"/>
                        </t:template>
                    </t:Column> -->

                </t:columns>
            </t:Table>
            <!-- End Table create place -->
        </VBox>

        <!-- Start - Footer -->
        <footer>
            <OverflowToolbar>
                <Button icon="sap-icon://warning2"  text="{ErrorModel>/Errors/0/text}"  type="Attention"  press="onMessageButtonPress"  visible="false" />
                <ToolbarSpacer />
                <Button type="Accept"  press="onQualitySubmit"  icon="sap-icon://save"  text="Submit"/>
                <Button   type="Reject" press="onTableitemCancel"  icon="sap-icon://cancel"  text="Cancel"/>
            </OverflowToolbar>
        </footer>
        <!-- End - Footer -->

    </Dialog>
</core1:FragmentDefinition>
