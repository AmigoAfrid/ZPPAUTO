<mvc:View
    controllerName="zautodesignapp.controller.ats.report.ats_report"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

    <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="ATS Report" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
								<layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false" class="sapUiSmallMarginBegin" />
                                    <DateRangeSelection id="Date" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value="" />

                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Batch No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialdocument" placeholder="Select Batch No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest"  suggest=".OnSuggest_User" suggestionItems="{
                                        path: 'ZSB_ATS_REPORT/ZATS_REPORT',
                                        sorter: { path: 'batch' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected">
                                    <suggestionItems>

                                    <core:Item key="{ZCE_ZCOUNT_HEAD_SRVB>batch}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>

                                    <layout:HorizontalLayout class=" sapUiLargeMarginBegin "><layout:HorizontalLayout class=" sapUiLargeMarginBegin "></layout:HorizontalLayout>


                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" /></layout:HorizontalLayout>

                                </layout:VerticalLayout>		
                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Process Ord No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idprocessorder" placeholder="Select Process Ord No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest_"  suggest=".OnSuggest_User_" suggestionItems="{
                                        path: 'ZSB_ATS_REPORT/ZCE_ZCOUNT_PROCEZATS_REPORTSS_ORD_F4HELP',
                                        sorter: { path: 'processorder' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_">
                                    <suggestionItems>

                                    <core:Item key="{ZSB_ATS_REPORT>processorder}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>
                                </layout:VerticalLayout>

                                  <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Material:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>                                   
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialats" placeholder="Select Material" editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestMaterial"  suggest=".OnSuggest_Usermaterial" suggestionItems="{
                                    path: 'ZAU_ATS_PROCESSORDER_SRVB>/ZCE_ATS_PROCESSORDER',
                                    sorter: { path: 'Product' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedMaterial">                        
                                    <suggestionItems>
                                    
                                    <core:Item key="{ZAU_ATS_PROCESSORDER_SRVB>Product}"></core:Item>
                                    
                                    </suggestionItems>
                                    
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>



                                	<layout:VerticalLayout  class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth" >
									<Label tooltip="Select Machine No"  required="false"  text="Select Machine No" design="Bold" />
								   <Input 
                                         
                                            type="Text"
											 id="id_atsmachinerep"
                                            editable="true"
                                            showValueHelp="true"
                                            value="{atsModel>/HeaderData/0/selectedMachine}"
                                            valueHelpIconSrc="sap-icon://value-help"
                                            valueHelpRequest="OnatsCheck"/>
								</layout:VerticalLayout>

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table
                rows="{path:'TabModel>/ItemData', sorter: {path: 'TabModel>item1'}}"
                selectionMode="None"
                enableSelectAll="false"
                id = "ats_report_table"
                rowMode="Auto" fixedColumnCount="5" >

                
                       <t:extension>
						<OverflowToolbar  style="Clear">
							<ToolbarSpacer/>
							<ToolbarSpacer/>
                   			 <Button id="_IDGenButtonATSscreen" icon="sap-icon://excel-attachment" press="OnExportExl"/>
						</OverflowToolbar>
					</t:extension>
                <t:columns>
				
                    <t:Column tooltip="Date" width="6rem">
                        <Label text="Date" />
                        <t:template>
                            <Text text="{path:'TabModel>zdate',formatter: '.formatDate'}" />
                        </t:template>
                    </t:Column>


                     <t:Column tooltip="Shift" width="4rem">
                        <Label text="Shift" />
                        <t:template>
                            <Text text="{TabModel>shift}" />
                        </t:template>
                    </t:Column>

                    
                    <t:Column tooltip="Acm No" width="4.5rem">
                        <Label text="Acm No" />
                        <t:template>
                            <Text text="{TabModel>acmno}" />
                        </t:template>
                    </t:Column>

                      
                    <t:Column tooltip="Customer Name" width="12rem">
                        <Label text="Customer Name" />
                        <t:template>
                            <Text text="{TabModel>customername}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Batch" width="6rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{TabModel>batch}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="boxno" width="4rem">
                        <Label text="BOX NO" />
                        <t:template>
                            <Text text="{TabModel>boxno}" />
                        </t:template>
                    </t:Column> 

                     <t:Column tooltip="Customer Code" width="8rem">
                        <Label text="Customer Code" />
                        <t:template>
                            <Text text="{TabModel>customer}" />
                        </t:template>
                    </t:Column>

                       <t:Column tooltip="Size" width="4rem">
                        <Label text="Size" />
                        <t:template>
                            <Text text="{TabModel>zsize}" />
                        </t:template>
                    </t:Column>


                           <t:Column tooltip="Material" width="7rem">
                        <Label text="Material" />
                        <t:template>
                            <Text text="{TabModel>material}" />
                        </t:template>
                    </t:Column>


                       <t:Column tooltip="Material Description" width="12rem">
                        <Label text="Material Description" />
                        <t:template>
                            <Text text="{TabModel>productdescription}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Process Ord" width="7.5rem">
                        <Label text="Process Order" />
                        <t:template>
                            <Text text="{TabModel>processorder}" />
                        </t:template>
                    </t:Column>

                   
                    <t:Column tooltip="Material Document No" width="10rem">
                        <Label text="Material Document No" />
                        <t:template>
                            <Text text="{TabModel>material}" />
                        </t:template>
                    </t:Column>

                      <t:Column tooltip="Agrade Qty" width="8rem">
                        <Label text="Agrade Qty" />
                        <t:template>
                            <Text text="{TabModel>agradeqty}" />
                        </t:template>
                    </t:Column>


                     <t:Column tooltip="Qty in lac" width="6.5rem">
                        <Label text="Qty in lac" />
                        <t:template>
                            <Text text="{path:'TabModel>tarqty', formatter:'.formatTotalCell'}" />
                        </t:template>
                    </t:Column>


                     <t:Column tooltip="Wastage in KGS" width="8rem">
                        <Label text="Wastage in KGS" />
                        <t:template>
                            <!-- <Text text="{TabModel>wastage}" /> -->
                             <Text text="{path:'TabModel>wastage', formatter:'.formatTotalCell'}" />
                        </t:template>
                    </t:Column>

                       <t:Column tooltip="Wastage in Lakhs" width="8rem">
                        <Label text="Wastage in Lakhs" />
                        <t:template>
                            <!-- <Text text="{TabModel>wastageinlac}" /> -->
                              <Text text="{path:'TabModel>wastageinlac', formatter:'.formatTotalCell'}" />
                        </t:template>
                    </t:Column>


                     <t:Column tooltip="Grade Ats" width="8rem">
                        <Label text="Grade ATS" />
                        <t:template>
                            <Text text="{TabModel>gradeats}" />
                        </t:template>
                    </t:Column>
                     <t:Column tooltip="Operator Name" width="8rem">
                        <Label text="Operator Name" />
                        <t:template>
                            <Text text="{TabModel>operatorname}" />
                        </t:template>
                    </t:Column>



                        <t:Column tooltip="Cumulative Qty" width="8rem">
                        <Label text="Cumulative Qty" />
                        <t:template>
                            <Text text="{TabModel>cumulativeqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Cumulative Qtys" width="8rem">
                        <Label text="Cumulative Qtys" />
                        <t:template>
                            <Text text="{TabModel>cumulativeqtys}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Average Wt" width="8rem">
                        <Label text="Average Weight" />
                        <t:template>
                            <Text text="{TabModel>averagewt}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Weight" width="7rem">
                        <Label text="Weight" />
                        <t:template>
                            <Text text="{TabModel>weight}" />
                        </t:template>
                    </t:Column>


                    <t:Column tooltip="Remarks" width="8rem">
                        <Label text="Remarks" />
                        <t:template>
                            <Text text="{TabModel>remarks}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Floor Wastage" width="6.5rem">
                        <Label text="Floor Wastage" />
                        <t:template>
                            <!-- <Text text="{TabModel>floorwastage}" /> -->
                             <Text text="{path:'TabModel>floorwastage', formatter:'.formatTotalCell'}" />
                        </t:template>
                    </t:Column>

                      <t:Column tooltip="Material Document" width="10rem">
                        <Label text="Material Document" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Document Year" width="8rem">
                        <Label text="Document Year" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentyear}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Qa Name" width="8rem">
                        <Label text="Qa Name" />
                        <t:template>
                            <Text text="{TabModel>qaname}" />
                        </t:template>
                    </t:Column>
                       <t:Column tooltip="HFX" width="6rem">
                        <Label text="HFX" />
                        <t:template>
                            <Text text="{TabModel>hfx}" />
                        </t:template>
                    </t:Column>

                    <t:Column  visible = "false" tooltip="Status" width="8rem">
                        <Label text="Status" />
                        <t:template>
                            <Text text="{TabModel>status}" />
                        </t:template>
                    </t:Column>

                    <t:Column visible = "false"  tooltip="Item Status" width="8rem">
                        <Label text="Item Status" />
                        <t:template>
                            <Text text="{TabModel>itemstatus}" />
                        </t:template>
                    </t:Column>

                    <t:Column visible = "false"  tooltip="Screencode" width="8rem">
                        <Label text="Screencode" />
                        <t:template>
                            <Text text="{TabModel>screencode}" />
                        </t:template>
                    </t:Column>

                </t:columns>

            </t:Table>
        </f:content>
        <!-- DynamicPage Footer -->
    </f:DynamicPage>


</mvc:View>
