<mvc:View
    controllerName="zautodesignapp.controller.acm.report.acm_report"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

    <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="ACM Report" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
								<layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false" class="sapUiSmallMarginBegin" />
                                    <DateRangeSelection id="Date" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value="" />

                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Batch No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialdocument" placeholder="Select Batch No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest"  suggest=".OnSuggest_User" suggestionItems="{
                                        path: 'ZSB_AU_ACM_ITEM>/ZC_AU_ACM_ITEM',
                                        sorter: { path: 'batch' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected">
                                    <suggestionItems>

                                    <core:Item key="{ZSB_AU_ACM_ITEM>batch}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>

                                    <layout:HorizontalLayout class=" sapUiLargeMarginBegin "><layout:HorizontalLayout class=" sapUiLargeMarginBegin "></layout:HorizontalLayout>


                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPageACM" enabled="true" /></layout:HorizontalLayout>

                                </layout:VerticalLayout>	

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Plant No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idPlantInput" placeholder="Select Plant" editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestPlant"  suggest=".OnSuggest_UserPlant" suggestionItems="{
                                    path: 'ZCE_ZCOUNT_HEAD_SRVB>/ZCE_PLANT_F4HELP',
                                    sorter: { path: 'plant' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedPlant">
                                    
                                    <suggestionItems>
                                    
                                    <core:Item key="{ZCE_ZCOUNT_HEAD_SRVB>plant}"></core:Item>
                                    
                                    </suggestionItems>
                                    
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label tooltip="Select Machine No" required="false" text="Select Machine No" design="Bold" />
                                    <Input
                                        id="idacmvalue"
                                        type="Text"
                                        editable="true"
                                        showValueHelp="true"
                                        placeholder="Select Machine No." 
                                        value="{acmModel>/HeaderData/0/selectedMachine}"
                                        valueHelpIconSrc="sap-icon://value-help"
                                        valueHelpRequest="OnAcmCheck" />
                                </layout:VerticalLayout>

                                    <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Material:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>                                   
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterials" placeholder="Select Material" editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestMaterial"  suggest=".OnSuggest_Usermaterial" suggestionItems="{
                                    path: 'ZAU_ACM_PROCESSORDER_SRVB>/ZCE_ACM_PROCESSORDER',
                                    sorter: { path: 'Product' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedMaterial">                        
                                    <suggestionItems>
                                    
                                    <core:Item key="{ZAU_ACM_PROCESSORDER_SRVB>Product}"></core:Item>
                                    
                                    </suggestionItems>
                                    
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>	


                                 <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Process Ord No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idprocessorders" placeholder="Select Process Ord No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest_"  suggest=".OnSuggest_User_" suggestionItems="{
                                        path: 'ZCE_ZCOUNT_HEAD_SRVB/ZCE_ZCOUNT_BATCH_F4HELP',
                                        sorter: { path: 'ProcessOrder' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_">
                                    <suggestionItems>

                                    <core:Item key="{ZCE_ZCOUNT_BATCH_F4HELP>ProcessOrder}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>
                                    </layout:VerticalLayout>

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table
                rows="{path:'TabModel>/ItemData', sorter: {path: 'TabModel>item1'}}"
                id="acm_report_table_id"
                selectionMode="None"
                enableSelectAll="false"
                rowMode="Auto"
                   fixedColumnCount="4"
                >

                  <t:extension>
						<OverflowToolbar  style="Clear">
							<ToolbarSpacer/>
							<ToolbarSpacer/>
                   			 <Button id="_IDGenButton1" icon="sap-icon://excel-attachment" press="OnExportExl"/>
						</OverflowToolbar>
					</t:extension>


                <t:columns>
				
                    <t:Column tooltip="Date" width="6rem">
                        <Label text="Date" />
                        <t:template>
                            <Text text="{path:'TabModel>zdate',formatter: '.formatDate'}"  />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Acm No" width="4.5rem">
                        <Label text="Acm No" />
                        <t:template>
                            <Text text="{TabModel>acmno}" />
                        </t:template>
                    </t:Column>

                          <t:Column tooltip="Shift" width="4.5rem">
                        <Label text="Shift" />
                        <t:template>
                            <Text text="{TabModel>shift}" />
                        </t:template>
                    </t:Column>


                    <t:Column tooltip="Batch" width="8rem">
                        <Label text="Batch No" />
                        <t:template>
                            <Text text="{TabModel>batch}" />
                        </t:template>
                    </t:Column>


                         <t:Column tooltip="Material" width="8.5rem">
                        <Label text="Material" />
                        <t:template>
                            <Text text="{TabModel>material}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Material Description" width="10.5rem">
                        <Label text="Material Description" />
                        <t:template>
                            <Text text="{TabModel>description}" />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Cumm Qty Lakh" width="8rem">
                        <Label text="Cumm Qty Lakh" />
                        <t:template>
                            <Text text="{TabModel>cummulativeinlaksh}" />
                        </t:template>
                    </t:Column>


                    <t:Column tooltip="Dips Cur" width="8rem">
                        <Label text="DIPS CURRENT" />
                        <t:template>
                            <Text text="{TabModel>dipscurrent}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Dips Cum" width="8rem">
                        <Label text="DIPS CUMULATIVE" />
                        <t:template>
                            <Text text="{TabModel>cumulative}" />
                        </t:template>
                    </t:Column>


                    
                    <!-- <t:Column tooltip="Plant" width="6rem">
                        <Label text="Plant" />
                        <t:template>
                            <Text text="{TabModel>plant}" />
                        </t:template>
                    </t:Column> -->
     
                    <t:Column tooltip="Plant" width="4rem">
                        <Label text="Plant" />
                        <t:template>
                            <Text text="{TabModel>plant}" />
                        </t:template>
                    </t:Column>

    
                     <t:Column tooltip="HFX" width="5.5rem">
                        <Label text="HFX Wastage" />
                        <t:template>
                            <Text text="{TabModel>hfx}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Wastage" width="5.5rem">
                        <Label text="Wastage" />
                        <t:template>
                            <Text text="{TabModel>wastage}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Floor Wastage" width="5rem">
                        <Label text="Floor Wastage" />
                        <t:template>
                            <Text text="{TabModel>floorwastage}" />
                        </t:template>
                    </t:Column>


                    
                    <t:Column tooltip="Operator Name" width="8rem">
                        <Label text="Operator Name" />
                        <t:template>
                            <Text text="{TabModel>operatorname}" />
                        </t:template>
                    </t:Column>


                    
                    <t:Column tooltip="Process Ord" width="8rem">
                        <Label text="Process Order" />
                        <t:template>
                            <Text text="{TabModel>processorder}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Cap Cut Qty" width="6rem">
                        <Label text="Cap Cut Qty" />
                        <t:template>
                            <Text text="{TabModel>capcutqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Body Cut Qty" width="8rem">
                        <Label text="Body Cut Qty" />
                        <t:template>
                            <Text text="{TabModel>bodycutqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Cap Cake Qty" width="6rem">
                        <Label text="Cap Cake Qty" />
                        <t:template>
                            <Text text="{TabModel>capcakeqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Body Cake Qty" width="6rem">
                        <Label text="Body Cake Qty" />
                        <t:template>
                            <Text text="{path:'TabModel>bodycakeqty',formatter:'.formatTotalCell'}"/>
                        </t:template>
                    </t:Column>

     

                          <t:Column tooltip="Balance" width="6rem">
                        <Label text="Balance Qty" />
                        <t:template>
                            <Text text="{TabModel>balanceqty}" />
                        </t:template>
                    </t:Column>


                      <t:Column tooltip="Dips Pre" width="6rem">
                        <Label text="DIPS PRE" />
                        <t:template>
                            <Text text="{TabModel>dipsuptoprevious}" />
                        </t:template>
                    </t:Column>

                    

                   
                    <t:Column tooltip="Dips Qty Lakhs" width="8rem">
                        <Label text="Dips Qty Lakhs" />
                        <t:template>
                            <Text text="{path:'TabModel>dipsqtylakh',formatter:'.formatTotalCell'}"/>
                        </t:template>
                    </t:Column>



                   

                    <t:Column tooltip="Material Document No" width="10rem">
                        <Label text="Material Document No" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno}" />
                        </t:template>
                    </t:Column>


                    <t:Column tooltip="Material Document Year" width="12rem">
                        <Label text="Material Document Year" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentyear}" />
                        </t:template>
                    </t:Column>

                    <t:Column visible="false" tooltip="Status" width="8rem">
                        <Label text="Status" />
                        <t:template>
                            <Text text="{TabModel>status}" />
                        </t:template>
                    </t:Column>

                    <t:Column visible="false" tooltip="Item Status" width="8rem">
                        <Label text="Item Status" />
                        <t:template>
                            <Text text="{TabModel>itemstatus}" />
                        </t:template>
                    </t:Column>

                    <t:Column  visible="false" tooltip="Screencode" width="8rem">
                        <Label text="Screencode" />
                        <t:template>
                            <Text text="{TabModel>screencode}" />
                        </t:template>
                    </t:Column>

                    <!-- <t:Column tooltip="cummulativeinlaksh" width="5rem">
                        <Label text="cummulativeinlaksh" />
                        <t:template>
                        <Text text="{
                        parts: [
                            { path: 'TabModel>cummulativeinlaksh' },
                            { path: 'TabModel>isTotalRow' }
                        ],
                        formatter: '.formatTotalCell'
                        }" />                        
                        </t:template>
                    </t:Column> -->
                </t:columns>

            </t:Table>
        </f:content>
        <!-- DynamicPage Footer -->
    </f:DynamicPage>


</mvc:View>
