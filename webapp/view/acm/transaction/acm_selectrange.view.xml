                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Body Colour:" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/BodyColor}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Cap Colour:" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/CapColor}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="QTY to MFD(Lakhs):" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/QtytoMfdLakhs}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="QTY to MFD(DIPS):" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/QtytoMfdDips}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Material :" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/Product}" editable="false" />
                                </layout:VerticalLayout>


                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Customer Name :" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/CustomerName}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Description :" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/ProductDescription}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Size :" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/Zsize}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Acm Speed:" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/speed}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Batch:" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/Batch}" editable="false" />
                                </layout:VerticalLayout>


                                    <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Plant:" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/plant}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Start Date :" class="sapUiSmallMarginTop" />
                                    <Input value="{path:'screen2model>/HEADERDATA/CreationDate',formatter: '.OnDateFormatChange'}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="No.Of Bar :" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/bar}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth" visible="true">
                                    <Label text="Start Time:" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/currentTime}" editable="false" />
                                </layout:VerticalLayout>
                            
                            
                            
                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>		
		

