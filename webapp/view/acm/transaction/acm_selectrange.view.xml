                        </t:template>
                    </t:Column>
                
                    <t:Column tooltip="Date" width="9rem" >
                        <Label text="Date" required="true" />
                        <t:template>
                            <DatePicker valueFormat="yyyy-MM-dd" displayFormat="dd-MM-yyyy" editable="{= ${TabItemModel>itemstatus} === 'open' ? false : true}"
                            value="{ 'path':'TabItemModel>zdate', 'type':'sap.ui.model.type.Date', 'formatOptions': { 'pattern': 'dd-MM-yyyy' } }" 
                            change=".onDateOrShiftChange"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Shift" width="5rem">
                        <Label text="Shift" required="true" />
                        <t:template>
                            <ComboBox selectedKey="{TabItemModel>shift}" width="11rem" items="{path: 'shiftmodel>/shfitsample'}" editable="{= ${TabItemModel>itemstatus} === 'open' ? false : true}" change=".onDateOrShiftChange">
                                <core:Item key="{shiftmodel>shiftname}" text="{shiftmodel>shiftname}" />
                            </ComboBox>
