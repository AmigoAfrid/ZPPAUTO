<mvc:View
    controllerName="zautodesignapp.controller.acm.transaction.acm_selectrange"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:u="sap.ui.unified"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	xmlns:f="sap.f"
	xmlns:layout="sap.ui.layout"
    height="100%">


    <!-- Screen 1 -->
    <f:DynamicPage
        visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="ACM Selection Screen" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox id="idflexboxacm" alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>

                                <layout:VerticalLayout
                                    visible="true"
                                    class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="true" />
                                    <DateRangeSelection
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="yyyy-MM-dd"
                                        tooltip="DatePicker"
                                        width="11.5rem"
                                        value="{acmModel>/HeaderData/0/daterange}" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label tooltip="Select Machine No" required="true" text="Select Machine No" design="Bold" />
                                    <Input
                                        id="idacmvalue"
                                        type="Text"
                                        editable="true"
                                        showValueHelp="true"
                                        value="{acmModel>/HeaderData/0/selectedMachine}"
                                        valueHelpIconSrc="sap-icon://value-help"
                                        valueHelpRequest="OnAcmCheck" />
                                </layout:VerticalLayout>

                                <Toolbar style="Clear">
                                    <ToolbarSpacer />
                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="GoAcmselect" enabled="true" />
                                    <ToolbarSpacer />
                                </Toolbar>

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <t:Table
                visible="{acmModel>/TableVisible}"
                rows="{path:'tabACMModel>/ItemData'}"
                selectionMode="Single"
                enableSelectAll="false"
                rowMode="Auto" fixedColumnCount="2"
                rowSelectionChange="onRowSelect">

                <t:extension>
                    <OverflowToolbar style="Clear">
                        <Title text="Items" />
                        <ToolbarSpacer />
                        <ToolbarSpacer />
                    </OverflowToolbar>
                </t:extension>

                <t:columns>
                    <t:Column tooltip="ACM No." width="4.6rem">
                        <Label text="ACM No." />
                        <t:template>
                            <Text text="{tabACMModel>ACMNO}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Production Order" width="6rem">
                        <Label text="Production Order" />
                        <t:template>
                            <Text text="{tabACMModel>ProcessOrder}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Start Date" width="6rem">
                        <Label text="Start Date" />
                        <t:template>
                            <Text text="{path:'tabACMModel>CreationDate', formatter: '.OnDateFormatChange'}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Batch" width="5rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{tabACMModel>Batch}" />
                        </t:template>
                    </t:Column>
                    <t:Column visible="false" tooltip="Material" width="9rem">
                        <Label text="Material" />
                        <t:template>
                            <Text text="{tabACMModel>Product}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Material Description" width="9rem">
                        <Label text="Material Description" />
                        <t:template>
                            <Text text="{tabACMModel>ProductDescription}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Sales order -Item" width="6rem">
                        <Label text="Sales order -Item" />
                        <t:template>
                            <Text text="{tabACMModel>SalesOrder}" />
                        </t:template>
                    </t:Column>
                    <t:Column visible="false" tooltip="Customer" width="9rem">
                        <Label text="Customer" />
                        <t:template>
                            <Text text="{tabACMModel>Customer}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Customer Name" width="8rem">
                        <Label text="Customer Name" />
                        <t:template>
                            <Text text="{tabACMModel>CustomerName}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Order QTY" width="6rem">
                        <Label text="Order QTY" />
                        <t:template>
                            <Text text="{tabACMModel>QtytoMfdLakhs}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Size" width="4rem">
                        <Label text="Size" />
                        <t:template>
                            <Text text="{tabACMModel>Zsize}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Cap colour" width="6rem">
                        <Label text="Cap colour" />
                        <t:template>
                            <Text text="{tabACMModel>CapColor}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Body Colour" width="6rem">
                        <Label text="Body Colour" />
                        <t:template>
                            <Text text="{tabACMModel>BodyColor}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="QTY to MFD(Lakhs)" width="5rem">
                        <Label text="QTY to MFD(Lakhs)" />
                        <t:template>
                            <Text text="{tabACMModel>QtytoMfdLakhs}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="QTY to MFD(DIPS)" width="5rem">
                        <Label text="QTY to MFD(DIPS)" />
                        <t:template>
                            <Text text="{tabACMModel>QtytoMfdDips}" />
                        </t:template>
                    </t:Column>
                    <t:Column tooltip="Status" width="5rem">
                        <Label text="Status" />
                        <t:template>
                            <Text text="{tabACMModel>Status}" />
                        </t:template>
                    </t:Column>
                </t:columns>
            </t:Table>
        </f:content>
    </f:DynamicPage>



 <!-- Screen 2 -->
    <f:DynamicPage
