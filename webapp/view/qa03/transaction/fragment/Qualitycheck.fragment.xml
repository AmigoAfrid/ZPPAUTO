<core1:FragmentDefinition xmlns="sap.m"
 xmlns:core1="sap.ui.core"
  xmlns:mvc="sap.ui.core.mvc"
   xmlns:u="sap.ui.unified"
    xmlns:t="sap.ui.table"
    xmlns:m="sap.f"
    xmlns:layout1="sap.ui.layout"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
 
<Dialog id="id_qualitycheck03" title="FINAL QUALITY CHECK ASSESSMENT - PRINTED CAPSULES - FCQ(QA03) ASSESSMENT" showHeader="true" verticalScrolling="true" horizontalScrolling="true" contentHeight="100%" contentWidth="100%" resizable="true" draggable="true" >
 
  <VBox class="sapUiTinyMarginTop">
    <Title text="" level="H3" class="sapUiTinyMarginBottom"/>

    <HBox wrap="Wrap" justifyContent="Start">
        <VBox class="sapUiSmallMargin">
            <Label text="Shift :" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/shifts}"  maxLength="250" placeholder="Enter value..."/>
        </VBox>

         <VBox class="sapUiSmallMargin">
            <Label text="Date :" width="150px"/>
            <Input value= "{path:'defectmodel>/HeaderdefectData/CreationDate', formatter: '.OnDateFormatChange'}" editable ="false" maxLength="250" placeholder="Enter value..."/>
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="Batch No:" width="150px"/>
            <Input  value = "{defectmodel>/HeaderdefectData/Batch}"  editable="false" />
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="Cap Color:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/CapColor}" editable="false" />
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="Cap INK Color:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/CapInkColor}" maxLength="250" placeholder="Enter value..."/>
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="Cap Print Text:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/CapPrintText}" maxLength="250" placeholder="Enter value..."/>
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="PRT MC No:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/PRTMCNO}"  maxLength="250" placeholder="Enter value..."/>
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="Capsule Size:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/Capsulesize}" maxLength="250" placeholder="Enter value..."/>
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="Body Color:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/BodyColor}" editable="false"/>
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="Body INK Color:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/BodyInkColor}"  maxLength="250" placeholder="Enter value..."/>
        </VBox>

        <VBox class="sapUiSmallMargin">
            <Label text="Body Print Text:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/Bodyprinttext}" maxLength="250" placeholder="Enter value..."/>
        </VBox>


          <VBox class="sapUiSmallMargin">
            <Label text="Operator:" width="150px"/>
            <Input  value= "{defectmodel>/HeaderdefectData/Oprator}" maxLength="250" placeholder="Enter value..."/>
        </VBox>

          <VBox class="sapUiSmallMargin">
            <Label text="Print Type:" width="150px"/>
      <Input  value= "{defectmodel>/HeaderdefectData/printtype}" maxLength="250" placeholder="Enter value..."/>
        </VBox>


           <VBox class="sapUiSmallMargin">
            <Label text="Reference SOP NO:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/Referencesopno}" maxLength="250" placeholder="Enter value..."/>
        </VBox>

        
           <VBox class="sapUiSmallMargin">
            <Label text="Format No:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/formatno}" maxLength="250" placeholder="Enter value..."/>
        </VBox>

        
           <VBox class="sapUiSmallMargin">
            <Label text="Revision No:" width="150px"/>
            <Input value= "{defectmodel>/HeaderdefectData/Revision NO}" maxLength="250" placeholder="Enter value..."/>
        </VBox>
    </HBox>
</VBox>
    <VBox class="sapUiSmallMargin">
        <!-- Coding Place -->
        <!-- Start Table create place -->
        <Title text="Visual Defects" level="H3" class="sapUiTinyMarginBottom"/>
        <t:Table  rows="{path: 'JModel1>/critical'}" selectionMode="None" rowMode="fixed">
                <t:extension>
                    <OverflowToolbar style="Clear">
                        <Title text="Defects Table"/>
                    </OverflowToolbar>
                </t:extension>
                <t:columns>
                    <t:Column width="4rem" hAlign="Left">
                        <Label text="S.No."/>
                            <t:template>
                                <Text text="{JModel1>sno}"/>
                            </t:template>
                    </t:Column>
                    <t:Column width="11rem" hAlign="Left">
                        <Label text="Critical Defects"/>
                            <t:template>
                                <Text text="{JModel1>defects}"/>
                            </t:template>
                    </t:Column>
                    <t:Column width="5rem" hAlign="Left">
                        <Label text="Norm"/>
                            <t:template>
                                 <Text  text="{JModel1>norm}"  width="100%" />
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After Printing"/>
                            <t:template>
                                <Input    value="{JModel1>afterprinting}"   width="100%"  placeholder="" liveChange=".onGradingValueChange" editable="{= ${JModel1>l1_status} === '' ? true : false}"  />
                            </t:template>
                    </t:Column>
                    <t:Column width="auto" hAlign="Left">
                        <Label text="After 1ST Sorting"/>
                            <t:template>
                                <Input   value="{JModel1>after1stsorting}"    width="100%"  editable="{= ${JModel1>l2_status} === '' ? true : false}"   placeholder="" />
                            </t:template>
                    </t:Column>

                       <t:Column width="auto" hAlign="Left">
                        <Label text="After 2nd Sorting"/>
                            <t:template>
                                <Input   value="{JModel1>after2ndsorting}"    width="100%"  editable="{= ${JModel1>l3_status} === '' ? true : false}"   placeholder="" />
                            </t:template>
                    </t:Column>


                     <t:Column width="auto" hAlign="Left">
                        <Label text="After 3rd Sorting"/>
                            <t:template>
                                <Input value="{JModel1>after3rdsorting}"  editable="{= ${JModel1>l4_status} === '' ? true : false}" placeholder="" />
                            </t:template>
                    </t:Column>
                    
                </t:columns>
            </t:Table>

            
            <t:Table
            rows="{JModel2>/major}"
            selectionMode="None"
            rowMode="fixed">

            <t:extension>
                    <OverflowToolbar 
                    style="Clear">
                        <Title text="Major Table"/>
                    </OverflowToolbar>
                </t:extension>

                <t:columns>
                    <t:Column
                    width="4rem"
                    hAlign="Left">
                        <Label text="S.No."/>
                            <t:template>
                                <Text text="{JModel2>sno}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="11rem"
                    hAlign="Left">
                        <Label text="Major Defects"/>
                            <t:template>
                                <Text text="{JModel2>defects}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="5rem"
                    hAlign="Left">
                        <Label text="Norm"/>
                            <t:template>
                                <Text 
                                    text="{JModel2>norm}" 
                                    width="100%" />
                            </t:template>
                    </t:Column>

                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After Printing"/>
                            <t:template>
                                <Input  
                                    value="{JModel2>afterprinting}" 
                                    width="100%"
                                    placeholder=""
                                    editable="{= ${JModel2>l1_status} === '' ? true : false}"
                                    />
                            </t:template>


                                <!-- <t:template>
                                <Input  
                                    value="{JModel2>afterprinting}" 
                                    width="100%"
                                    placeholder=""
            
                                    />
                            </t:template> -->

                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After 1ST Sorting"/>
                            <t:template>
                                <Input
                                    value="{JModel2>after1stsorting}" 
                                    width="100%"
                                   editable="{= ${JModel2>l2_status} === '' ? true : false}"
                                    placeholder="" />
                            </t:template>
                    </t:Column>

                       <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After 2nd Sorting"/>
                            <t:template>
                                <Input
                                    value="{JModel2>after2ndsorting}" 
                                    width="100%"
                                    editable="{= ${JModel2>l3_status} === '' ? true : false}"
                                    placeholder="" />
                            </t:template>
                    </t:Column>


                     <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After 3rd Sorting"/>
                            <t:template>
                                <Input
                                    value="{JModel2>after3rdsorting}" 
                                    width="100%"
                                    editable="{= ${JModel2>l4_status} === '' ? true : false}"
                                    placeholder="" />
                            </t:template>
                    </t:Column>
                   
                </t:columns>
            </t:Table>
            <t:Table
            rows="{JModel3>/minor}"
            selectionMode="None"
            rowMode="fixed">

            <t:extension>
                    <OverflowToolbar 
                    style="Clear">
                        <Title text="Minor Table"/>
                    </OverflowToolbar>
                </t:extension>

                <t:columns>
                    <t:Column
                    width="4rem"
                    hAlign="Left">
                        <Label text="S.No."/>
                            <t:template>
                                <Text text="{JModel3>sno}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="11rem"
                    hAlign="Left">
                        <Label text="Minor Defects"/>
                            <t:template>
                                <Text text="{JModel3>defects}"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="5rem"
                    hAlign="Left">
                        <Label text="Norm"/>
                            <t:template>
                                <Text 
                                    text="{JModel3>norm}" 
                                    width="100%"/>
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After Printing"/>
                            <t:template>
                                <Input  
                                    value="{JModel3>afterprinting}" 
                                    width="100%"
                                    placeholder=""
                                    editable="{= ${JModel3>l1_status} === '' ? true : false}"
                                    />
                            </t:template>
                    </t:Column>
                    <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After 1ST Sorting"/>
                            <t:template>
                                <Input
                                    value="{JModel3>after1stsorting}" 
                                    width="100%"
                                    editable="{= ${JModel3>l2_status} === '' ? true : false}"
                                    placeholder="" />
                            </t:template>
                    </t:Column>

                       <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After 2nd Sorting"/>
                            <t:template>
                                <Input
                                    value="{JModel3>after2ndsorting}" 
                                    width="100%"
                                    editable="{= ${JModel3>l3_status} === '' ? true : false}"
                                    placeholder="" />
                            </t:template>
                    </t:Column>


                     <t:Column
                    width="auto"
                    hAlign="Left">
                        <Label text="After 3rd Sorting"/>
                            <t:template>
                                <Input
                                    value="{JModel3>after3rdsorting}" 
                                    width="100%"
                                    editable="{= ${JModel3>l4_status} === '' ? true : false}"
                                    placeholder="" />
                            </t:template>
                    </t:Column>
                </t:columns>
            </t:Table>
        <!-- End Table create place -->

        <!-- <VBox class="sapUiSmallMarginTop">
            <Title text="Section2-placehlder for now" level="H3" class="sapUiTinyMarginBottom"/>
                <FlexBox direction="Row" alignItems="Center" class="sapUiSmallMarginTop">
                    <Label text="Field Name:" labelFor="section2Input" width="150px"/>
                    <Input  placeholder="Enter value..." width="300px"/>
                </FlexBox>
        </VBox> -->


      

  

    </VBox>
 
<!-- Start - Footer  -->
        <footer>
            <OverflowToolbar>
                <Button id="messagePopoverBtn" icon="sap-icon://warning2" text="{ErrorModel>/Errors/0/text}" type="Attention" press="onMessageButtonPress" visible="false" />
                <ToolbarSpacer />
                <!-- <Button press="onQualitySubmit" icon="sap-icon://save" text="Submit"/>
                <Button press="onQualityCancel" icon="sap-icon://cancel" text="Cancel"/>                                 -->
                <Button visible="{BtnBasedModel>/Samples/save_btn}" press="onQualitySubmit" icon="sap-icon://save" text="Submit"/>
                <Button visible="{BtnBasedModel>/Samples/update_btn}" press="onQualityUpdate" icon="sap-icon://save" text="Update"/>
                <Button press="onQualityCancel" icon="sap-icon://cancel" text="Cancel"/>

            </OverflowToolbar>
        </footer>
<!-- End - Footer  -->
 
</Dialog>
 
 
</core1:FragmentDefinition>