<mvc:View
    controllerName="zautodesignapp.controller.qa01.report.qa01_report"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

    <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="QA01 Report" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
								<layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false" class="sapUiSmallMarginBegin" />
                                    <DateRangeSelection id="Date" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value="" />

                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Batch No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialdocument" placeholder="Select Batch No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest"  suggest=".OnSuggest_User" suggestionItems="{
                                        path: 'ZCE_ZCOUNT_HEAD_SRVB/ZCE_ZCOUNT_BATCH_F4HELP',
                                        sorter: { path: 'batch' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected">
                                    <suggestionItems>

                                    <core:Item key="{ZCE_ZCOUNT_BATCH_F4HELP>batch}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>

                                    <layout:HorizontalLayout class=" sapUiLargeMarginBegin "><layout:HorizontalLayout class=" sapUiLargeMarginBegin "></layout:HorizontalLayout>


                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" /></layout:HorizontalLayout>

                                </layout:VerticalLayout>	
                                 <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Process Ord No." design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idprocessorder" placeholder="Select Process Ord No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest_"  suggest=".OnSuggest_User_" suggestionItems="{
                                        path: 'ZCE_ZCOUNT_HEAD_SRVB/ZCE_ZCOUNT_BATCH_F4HELP',
                                        sorter: { path: 'ProcessOrder' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_">
                                    <suggestionItems>

                                    <core:Item key="{ZCE_ZCOUNT_BATCH_F4HELP>ProcessOrder}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>
                                    </layout:VerticalLayout>	

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table
                rows="{path:'TabModel>/ItemData', sorter: {path: 'TabModel>item1'}}"
                selectionMode="None"
                enableSelectAll="false"
                rowMode="Auto">
                <t:columns>
				
                    <t:Column tooltip="Date" width="8rem">
                        <Label text="Date" />
                        <t:template>
                            <Text text="{path:'TabModel>zdate',formatter: '.OnDateChangeValue'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Batch" width="8rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{TabModel>batch}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Process Ord" width="8rem">
                        <Label text="Process Ord" />
                        <t:template>
                            <Text text="{TabModel>processorder}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Shift" width="5rem">
                        <Label text="Shift" />
                        <t:template>
                            <Text text="{TabModel>shift}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="boxno" width="5rem">
                        <Label text="boxno" />
                        <t:template>
                            <Text text="{TabModel>boxno}" />
                        </t:template>
                    </t:Column>


                    <t:Column tooltip="Acm No." width="5rem">
                        <Label text="Acm No." />
                        <t:template>
                            <Text text="{TabModel>acmno}" />
                        </t:template>
                    </t:Column>
                    
                    <t:Column tooltip="Material Document No." width="8rem">
                        <Label text="Material Document No." />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Average Wt" width="8rem">
                        <Label text="Average Wt" />
                        <t:template>
                            <Text text="{TabModel>averagewt}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Weight" width="8rem">
                        <Label text="Weight" />
                        <t:template>
                            <Text text="{TabModel>weight}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Cumulative Qty" width="8rem">
                        <Label text="Cumulative Qty" />
                        <t:template>
                            <Text text="{TabModel>cumulativeqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Cumulative Qtys" width="8rem">
                        <Label text="Cumulative Qtys" />
                        <t:template>
                            <Text text="{TabModel>cumulativeqtys}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Grade Ats" width="8rem">
                        <Label text="Grade Ats" />
                        <t:template>
                            <Text text="{TabModel>gradeats}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Grade Ais" width="8rem">
                        <Label text="Grade Ais" />
                        <t:template>
                            <Text text="{TabModel>gradeais}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Target Qty" width="8rem">
                        <Label text="Target Qty" />
                        <t:template>
                            <Text text="{TabModel>tarqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Agrade Qty" width="8rem">
                        <Label text="Agrade Qty" />
                        <t:template>
                            <Text text="{TabModel>agradeqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Remarks" width="8rem">
                        <Label text="Remarks" />
                        <t:template>
                            <Text text="{TabModel>remarks}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="HFX" width="8rem">
                        <Label text="HFX" />
                        <t:template>
                            <Text text="{TabModel>hfx}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Wastage" width="8rem">
                        <Label text="Wastage" />
                        <t:template>
                            <Text text="{TabModel>wastage}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Floor Wastage" width="8rem">
                        <Label text="Floor Wastage" />
                        <t:template>
                            <Text text="{TabModel>floorwastage}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Qa Name" width="8rem">
                        <Label text="Qa Name" />
                        <t:template>
                            <Text text="{TabModel>qaname}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Operator Name" width="8rem">
                        <Label text="Operator Name" />
                        <t:template>
                            <Text text="{TabModel>operatorname}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Document Year" width="8rem">
                        <Label text="Document Year" />
                        <t:template>
                            <Text text="{TabModel>documentyear}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Status" width="8rem">
                        <Label text="Status" />
                        <t:template>
                            <Text text="{TabModel>status}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Item Status" width="8rem">
                        <Label text="Item Status" />
                        <t:template>
                            <Text text="{TabModel>itemstatus}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Screencode" width="5rem">
                        <Label text="Screencode" />
                        <t:template>
                            <Text text="{TabModel>screencode}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Balance" width="6rem">
                        <Label text="Balance Qty" />
                        <t:template>
                            <Text text="{TabModel>balanceqty}" />
                        </t:template>
                    </t:Column>

                </t:columns>

            </t:Table>
        </f:content>
        <!-- DynamicPage Footer -->
    </f:DynamicPage>


</mvc:View>
