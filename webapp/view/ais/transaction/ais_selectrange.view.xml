<mvc:View
    controllerName="zautodesignapp.controller.ais.transaction.ais_selectrange"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

<!-- screen 1 -->
    <f:DynamicPage
        visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="AIS Selection Screen" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
                                <!-- Date Range Selection -->
                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="true" />
                                    <DateRangeSelection
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="yyyy-MM-dd"
                                        tooltip="DatePicker"
                                        width="11.5rem"
                                        value="{aisModel>/HeaderData/0/daterange}" />
                                </layout:VerticalLayout>

                                <!-- Machine Selection -->
                                <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label tooltip="Select Machine No" required="true" text="Select Machine No" design="Bold" />
                                    <Input
                                        type="Text"
                                        id="id_aismachine"
                                        editable="true"
                                        showValueHelp="true"
                                        value="{aisModel>/HeaderData/0/selectedMachine}"
                                        valueHelpIconSrc="sap-icon://value-help"
                                        valueHelpRequest=".OnAisCheck" />
                                </layout:VerticalLayout>

                                <!-- Toolbar with Button -->
                                <Toolbar style="Clear">
                                    <ToolbarSpacer />
                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="Goaisselect" enabled="true" />
                                    <ToolbarSpacer />
                                </Toolbar>
                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table
                visible="{aisModel>/TableVisible}"
                rows="{path:'TabModel>/ItemData', sorter: {path: 'TabModel>item1'}}"
                selectionMode="Single"
                enableSelectAll="false"
                rowMode="Auto"
                rowSelectionChange="onRowSelect">

                <t:extension>
                    <OverflowToolbar style="Clear">
                        <Title text="Items" />
                        <ToolbarSpacer />
                        <ToolbarSpacer />
                        <!-- <Button icon="sap-icon://excel-attachment" press="OnExportExl" /> -->
                    </OverflowToolbar>
                </t:extension>

                <t:columns>
                    <!-- Column Definitions -->
                    <t:Column tooltip="Production Order" width="8rem">
                        <Label text="Production Order" />
                        <t:template>
                            <Text text="{TabModel>ManufacturingOrder}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Start Date" width="6rem">
                        <Label text="Start Date" />
                        <t:template>
                            <!-- <Text text="{TabModel>CreationDate}" /> -->
                            <Text  text="{path:'TabModel>CreationDate', formatter: '.OnDateFormatChange'}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Batch" width="6rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{TabModel>Batch}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Material" width="6rem">
                        <Label text="Material" />
                        <t:template>
                            <Text text="{TabModel>Product}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Description" width="6rem">
                        <Label text="Description" />
                        <t:template>
                            <Text text="{TabModel>ProductDescription}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Sales order -Item" width="6rem">
                        <Label text="Sales order -Item" />
                        <t:template>
                            <Text text="{TabModel>SalesOrder}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Customer" width="6rem">
                        <Label text="Customer" />
                        <t:template>
                            <Text text="{TabModel>Customer}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Customer Name" width="6rem">
                        <Label text="Customer Name" />
                        <t:template>
                            <Text text="{TabModel>CustomerName}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Size" width="6rem">
                        <Label text="Size" />
                        <t:template>
                            <Text text="{TabModel>Zsize}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Body Colour" width="6rem">
                        <Label text="Body Colour" />
                        <t:template>
                            <Text text="{TabModel>BodyColor}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Cap colour" width="6rem">
                        <Label text="Cap colour" />
                        <t:template>
                            <Text text="{TabModel>CapColor}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Direct Pass" width="6rem">
                        <Label text="Direct Pass" />
                        <t:template>
                            <Text text="{TabModel>DirectPass}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Sort" width="6rem">
                        <Label text="Sort" />
                        <t:template>
                            <Text text="{TabModel>Sort}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="HFX" width="6rem">
                        <Label text="HFX" />
                        <t:template>
                            <Text text="{TabModel>HFX}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Reject" width="6rem">
                        <Label text="Reject" />
                        <t:template>
                            <Text text="{TabModel>Reject}" />
                        </t:template>
                    </t:Column>

                </t:columns>
            </t:Table>
        </f:content>

        <!-- DynamicPage Footer -->
        <!-- 
        <f:footer>
            <OverflowToolbar id="overFlow">
                <Button icon="sap-icon://message-popup" text="{/messagesLength}" type="Emphasized" id="idBtn" press="onMessageButtonPress" visible="{= !!${/messagesLength}}"/>
                <ToolbarSpacer id="toolbarsapcer" />
                <Button visible="false" tooltip="Save" type="Accept" press="onGoToScreen2" id="Final_Save_Button" enabled="true" text="Next" icon="sap-icon://save" />
            </OverflowToolbar>
        </f:footer>
        -->
    </f:DynamicPage>


<!-- screen 2 -->
    <f:DynamicPage
        visible="{= ${ScreenVisible>/openscreen} === 'screen2' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true"
        xmlns:f="sap.f"
        xmlns="sap.m"
        xmlns:c="sap.ui.core">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="AIS Process" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Batch :" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/Batch}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Sales Order:" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/SalesOrder}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Order QTY(Lakhs):" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/MfgOrderPlannedTotalQty}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="ATS QTY :" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/ats_qty}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="ACM No:" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/AISButton}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Cap colour :" tooltip="Field" design="Bold" required="false" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/CapColor}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Body colour:" tooltip="Field" design="Bold" required="false" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/BodyColor}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Size :" tooltip="Field" design="Bold" required="false" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/Zsize}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Material:" tooltip="Field" design="Bold" required="false" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/Product}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Customer:" tooltip="Field" design="Bold" required="false" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/Customer}" editable="false" />
                                </layout:VerticalLayout>


                                 <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="Plant:" tooltip="Field" design="Bold" required="false" class="sapUiSmallMarginTop" />
                                    <Input value="{screen2model>/HEADERDATA/ProductionPlant}" editable="false" />
                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="false" class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label text="GR Text:" tooltip="Field" design="Bold" required="false" class="sapUiSmallMarginTop" />
                                    <Input value="" editable="false" />
                                </layout:VerticalLayout>

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table id="idqa01processcreen" visible="true"
                rows="{path:'TabItemModel>/Datassitem', sorter: {path: 'TabModel>item1'}}"
                selectionMode="None"
                enableSelectAll="false"
                rowMode="Auto"
                fixedColumnCount="3"
                selectionBehavior="Row"
                rowSelectionChange="onSelectionAisRow">

                <t:extension>
                    <OverflowToolbar style="Clear">
                        <Title text="Items" />
                        <ToolbarSpacer />
                        <ToolbarSpacer />
                        <!-- <Button icon="sap-icon://excel-attachment" press="OnExportExl" /> -->
                    </OverflowToolbar>
                </t:extension>

                <t:columns>

                
				<t:Column tooltip="Actions" width="6.5rem"> 
                        <Label text="Action" required="false" /> 
                        <t:template>
                            <MenuButton visible="true" text="Action">
                                <menu>
                                    <Menu itemSelected="onMenuAction">
                                        <MenuItem text="Print" icon="sap-icon://print" key="0"/>
                                       <!--  <MenuItem text="Cake Print" icon="sap-icon://print" key="1" /> -->
                                        <MenuItem text="Post Goods Issue" icon="sap-icon://create-entry-time" key="2" enabled="{= ${TabItemModel>materialdocumentno_gi} === '' ? true : false}"/>
                                        <MenuItem text="Reverse Goods Issue" icon="sap-icon://refresh" key="4"  enabled="{= ${TabItemModel>materialdocumentno_gi} === '' || ${TabItemModel>materialdocumentno_gr} !== ''  ?  false : true}"/>
                                        <MenuItem text="Post Goods Receipt" icon="sap-icon://create-entry-time" key="3"  enabled="{= ${TabItemModel>materialdocumentno_gr} === '' ? (${TabItemModel>materialdocumentno_gi} !== '' ? true : false) : false }"
                                         visible="{= ${TabItemModel>grageais} === 'D'? true : false }"/>
                                        <MenuItem text="Reverse Goods Receipt" icon="sap-icon://refresh" key="5" enabled="{= ${TabItemModel>materialdocumentno_gr} === ''  ? false : true}" visible="{= ${TabItemModel>grageais} === 'D'? true : false }" />
                                        <!-- <MenuItem text="AIS Wastage" icon="sap-icon://message-warning" key="6"/> -->

                                    </Menu>
                                </menu>
                            </MenuButton>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Select" width="3rem">
						<Label text="" />
						<t:template>
							<CheckBox selected="{TabItemModel>selected}" select="onCheckBoxSelect" visible="{= ${TabItemModel>materialdocumentno_gi} !== '' || ${TabItemModel>materialdocumentno_gr} !== '' ? false : true}"/>
						</t:template>
					</t:Column>

                    <t:Column tooltip="Date" width="8rem">
                        <Label text="Date" />
                        <t:template>
                            <DatePicker editable="false" 
                                value="{
                                    'path':'TabItemModel>zdate',
                                    'type':'sap.ui.model.type.Date',
                                    'formatOptions': {
                                        'pattern': 'dd-MM-yyyy'
                                    }
                                }" 
                                valueFormat="dd-MM-yyyy" 
                                displayFormat="dd-MM-yyyy"
                                change="onDateOrShiftChange" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Batch" width="8rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{TabItemModel>batch}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Shift" width="6rem">
                        <Label text="Shift" />
                        <t:template>
                            <Text text="{TabItemModel>shift}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="AIS Shift" width="6rem">
                        <Label text="AIS Shift" required="false"/>
                        <t:template>
                        <Text text="{TabItemModel>aisshift}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Box No" width="6rem">
                        <Label text="Box No" required="false"/>
                        <t:template>
                            <Text text="{TabItemModel>boxno}"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Average Weight" width="6rem">
                        <Label text="Average Weight" />
                        <t:template>
                            <Text text="{TabItemModel>averagewt}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="ATS Weight" width="6rem">
                        <Label text="ATS Weight" />
                        <t:template>
                            <Text text="{TabItemModel>atsweight}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="AIS Weight" width="6rem">
                        <Label text="AIS Weight" required="true"/>
                        <t:template>
<Input 
    value="{TabItemModel>weight}" 
    change="onAisWeightChange" 
    editable="{= ${TabItemModel>materialdocumentno_gi} !== '' || ${TabItemModel>materialdocumentno_gr} !== '' ? false : true}" enabled="{=${TabItemModel>grageais} === 'D' ? true : false}"
/>                    
   </t:template>
                    </t:Column>

                    <t:Column tooltip="Cumulative QTY" width="6rem">
                        <Label text="Cumulative QTY" />
                        <t:template>
                            <Text text="{TabItemModel>cumqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Grade for ATS" width="6rem">
                        <Label text="Grade for ATS" />
                        <t:template>
                            <Text text="{TabItemModel>gradeats}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Grade for AIS" width="6rem">
                        <Label text="Grade for AIS" />
                        <t:template>
                            <Text text="{TabItemModel>grageais}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="AIS Wastage in KGS" width="9rem">
                        <Label text="AIS Wastage in KGS" />
                        <t:template>
                          <Text text="{= ${TabItemModel>grageais} === 'D' ? ${TabItemModel>aiswastage} : ${TabItemModel>atsweight}}" />
                            <!-- <Text text="{=${TabItemModel>grageais} === 'D' ? {TabItemModel>aiswastage} : {TabItemModel>atsweight}}" /> -->
                            <!-- <Text text="{TabItemModel>aiswastage}" /> -->
                        </t:template>
                    </t:Column>

                       <t:Column tooltip="AIS Wastage in Lakhs" width="6rem">
                        <Label text="AIS Wastage in Lakhs" />
                        <t:template>
                          <Text text="{TabItemModel>wastageinlac}" />
                            <!-- <Text text="{=${TabItemModel>grageais} === 'D' ? {TabItemModel>aiswastage} : {TabItemModel>atsweight}}" /> -->
                            <!-- <Text text="{TabItemModel>aiswastage}" /> -->
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="QTY L" width="6rem">
                        <Label text="QTY L" />
                        <t:template>
                            <Text text="{TabItemModel>qtylitre}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="A grade QTY" width="6rem">
                        <Label text="A grade QTY" />
                        <t:template>
                            <Text text="{TabItemModel>agradeqty}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Cumulative Entry" width="6rem">
                        <Label text="Cumulative Entry" />
                        <t:template>
                            <Text text="{TabItemModel>cumulativeentry}" />
                        </t:template>
                    </t:Column>

                     

                    <t:Column tooltip="Remarks" width="6rem">
                        <Label text="Remarks" />
                        <t:template>
                            <TextArea value="{TabItemModel>remarks}" editable="{= ${TabItemModel>materialdocumentno_gi} !== '' || ${TabItemModel>materialdocumentno_gr} !== '' ? false : true}"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="HFX" width="6rem">
                        <Label text="HFX" />
                        <t:template>
                            <Input value="{TabItemModel>hfx}" editable="{= ${TabItemModel>materialdocumentno_gi} !== '' || ${TabItemModel>materialdocumentno_gr} !== '' ? false : true}"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Floor Wastage" width="6rem">
                        <Label text="Floor Wastage" />
                        <t:template>
                            <Input value="{TabItemModel>floorwaste}" editable="{= ${TabItemModel>materialdocumentno_gi} !== '' || ${TabItemModel>materialdocumentno_gr} !== '' ? false : true}"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="QA Name" width="6rem">
                        <Label text="QA Name" />
                        <t:template>
                            <Input value="{TabItemModel>qaname}" editable="false"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Operator Name" width="6rem">
                        <Label text="Operator Name" />
                        <t:template>
                            <Input value="{TabItemModel>operatorname}" editable="false"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="AIS Machine NO" width="6rem">
                        <Label text="AIS Machine NO" required="true" />
                        <t:template>
                            <Input value="{TabItemModel>aismachineno}" editable="{= ${TabItemModel>materialdocumentno_gi} !== '' || ${TabItemModel>materialdocumentno_gr} !== '' ? false : true}" />
                        </t:template>
                    </t:Column>

                         <t:Column tooltip="GI Material Document No" width="6rem">
                        <Label text="GI Material Document No" />
                        <t:template>
                            <Text text="{TabItemModel>materialdocumentno_gi}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="GI Material Document Year" width="6rem">
                        <Label text="GI Material Document Year" />
                        <t:template>
                            <Text text="{TabItemModel>materialdocumentyear_gi}" />
                        </t:template>
                    </t:Column>

                    <t:Column visible="false"  tooltip="Confirmation Group" width="6rem">
                        <Label text="Confirmation Group" />
                        <t:template>
                            <Text text="{TabItemModel>confirmationgroup}" />
                        </t:template>
                    </t:Column>

                    <t:Column  visible="false"  tooltip="Confirmation Count" width="6rem">
                        <Label text="Confirmation Countr" />
                        <t:template>
                            <Text text="{TabItemModel>confirmationcount}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="GR Material Document No" width="6rem">
                        <Label text="GR Material Document No" />
                        <t:template>
                            <Text text="{TabItemModel>materialdocumentno_gr}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="GR Material Document Year" width="6rem">
                        <Label text="GR Material Document Year" />
                        <t:template>
                            <Text text="{TabItemModel>materialdocumentyear_gr}" />
                        </t:template>
                    </t:Column>

                </t:columns>

            </t:Table>
        </f:content>

        <!-- DynamicPage Footer -->
        <f:footer>
            <OverflowToolbar>
                <!-- <Button icon="sap-icon://message-popup" text="{/messagesLength}" type="Emphasized" press="onMessageButtonPress" visible="{= !!${/messagesLength}}"/> -->
                <ToolbarSpacer />
                <Button tooltip="Go Back" type="Default" press="onGoToScreen1" enabled="true" text="Back" icon="sap-icon://close-command-field" />
                <!-- <Button tooltip="Save" type="Accept" press="onGoToScreen1" enabled="true" text="Back" icon="sap-icon://save" /> -->
                <!-- <Button tooltip="Save" type="Default" press=".onUpdateItemDataAIS" enabled="true" text="Update" icon="sap-icon://save" /> -->
                <Button tooltip="Save the document internally" type="Default" press=".onUpdateItemDataAIS" text="Update" icon="sap-icon://save" />

            </OverflowToolbar>
        </f:footer>

    </f:DynamicPage>

</mvc:View>
