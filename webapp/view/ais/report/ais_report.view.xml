<mvc:View
    controllerName="zautodesignapp.controller.ais.report.ais_report"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    height="100%">

    <f:DynamicPage
		visible="{= ${ScreenVisible>/openscreen} === 'screen1' }"
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="AIS Report" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>
								<layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin sapUiSmallMarginEnd  customWidth">

                                    <Label text="Select Date Range :" tooltip="DatePicker" design="Bold" required="false" class="sapUiSmallMarginBegin" />
                                    <DateRangeSelection id="Date" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" tooltip="DatePicker" width="10rem" value="" />

                                </layout:VerticalLayout>

                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Batch No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialdocument" placeholder="Select Batch No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest"  suggest=".OnSuggest_User" suggestionItems="{
                                        path: 'ZSB_AU_QA02_ITEM/ZC_AU_QA02ITEM',
                                        sorter: { path: 'batch' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected">
                                    <suggestionItems>

                                    <core:Item key="{ZSB_AU_QA02_ITEM>batch}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>

                                    <layout:HorizontalLayout class=" sapUiLargeMarginBegin "><layout:HorizontalLayout class=" sapUiLargeMarginBegin "></layout:HorizontalLayout>


                                    <Button text="Go" tooltip="Execute" type="Emphasized" press="OnGoItemPage" enabled="true" /></layout:HorizontalLayout>

                                </layout:VerticalLayout>	
                                <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Process Ord No:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idprocessorder" placeholder="Select Process Ord No." editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequest_"  suggest=".OnSuggest_User_" suggestionItems="{
                                        path: 'ZSB_AU_QA02_ITEM/ZC_AU_QA02ITEM',
                                        sorter: { path: 'processorder' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselected_">
                                    <suggestionItems>

                                    <core:Item key="{ZSB_AU_QA02_ITEM>processorder}"></core:Item>

                                    </suggestionItems>
                                    
                                    </MultiInput>
                                </layout:VerticalLayout>


                                     <layout:VerticalLayout visible="true" class="sapUiSmallMarginBegin ">

                                    <Label text="Material:" design="Bold"  required="false" labelFor="multiInputWithSuggestions"/>                                   
                                    
                                    <MultiInput maxLength="10" required="true" width="12.5rem" id="idmaterialais" placeholder="Select Material" editable="true" enabled="true"   showValueHelp="true" valueHelpRequest=".onValueHelpRequestMaterial"  suggest=".OnSuggest_Usermaterial" suggestionItems="{
                                    path: 'ZCE_ZCOUNT_HEAD_SRVB>/ZCE_PRODUCT_F4HELP',
                                    sorter: { path: 'Product' }}" showSuggestion="true"  suggestionItemSelected=".ondocumentsuggestselectedMaterial">                        
                                    <suggestionItems>
                                    
                                    <core:Item key="{ZCE_ZCOUNT_HEAD_SRVB>Product}"></core:Item>
                                    
                                    </suggestionItems>
                                    
                                    </MultiInput>
                                   
                                </layout:VerticalLayout>	


                                 <layout:VerticalLayout class="sapUiSmallMarginBegin sapUiSmallMarginEnd customWidth">
                                    <Label tooltip="Select Machine No" required="true" text="Select Machine No" design="Bold" />
                                    <Input
                                        type="Text"
                                        id="id_aismachines"
                                        editable="true"
                                        showValueHelp="true"
                                        value="{aisModel>/HeaderData/0/selectedMachine}"
                                        valueHelpIconSrc="sap-icon://value-help"
                                        valueHelpRequest=".OnAisCheck" />
                                </layout:VerticalLayout>		

                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>
        <t:Table
            rows="{path:'TabModel>/ItemData', sorter: {path: 'TabModel>item1'}}"
            selectionMode="MultiToggle"
            id="ais_report_table"
            enableSelectAll="true"
            rowMode="Auto"
            fixedColumnCount="5"
            rowSelectionChange=".onRowSelect"
            >
                  <t:extension>
						<OverflowToolbar  style="Clear">
							<ToolbarSpacer/>
							<ToolbarSpacer/>
                   			 <Button id="_IDGenButtonAisscreen" icon="sap-icon://excel-attachment" press="OnExportExl"/>
						</OverflowToolbar>
					</t:extension>
                <t:columns>

				
                    <t:Column tooltip="Date" width="6rem">
                        <Label text="Date" />
                        <t:template>
                            <Text text="{path:'TabModel>zdate',formatter: '.formatDate'}" />
                        </t:template>
                    </t:Column>


                   <t:Column tooltip="Process Ord No" width="11rem">
                        <Label text="Process Order No" />
                        <t:template>
                            <Text text="{TabModel>processorder}" />
                        </t:template>
                    </t:Column>

                    
                <t:Column tooltip="AIS Machine No" width="7.5rem">
                    <Label text="AIS Machine No" />
                    <t:template>
                        <Text text="{TabModel>aismachineno}" />
                    </t:template>
                </t:Column>


                   <t:Column tooltip="Customer Name" width="12rem">
                    <Label text="Customer Name" />
                    <t:template>
                        <Text text="{TabModel>customername}" />
                    </t:template>
                </t:Column>

                     <t:Column tooltip="Batch" width="6.5rem">
                        <Label text="Batch" />
                        <t:template>
                            <Text text="{TabModel>batch}" />
                        </t:template>
                    </t:Column>


                      <t:Column tooltip="Size" width="4rem">
                        <Label text="Size" />
                        <t:template>
                            <Text text="{TabModel>zsize}" />
                        </t:template>
                    </t:Column>

                    
                       <t:Column tooltip="Material" width="6rem">
                        <Label text="Material" />
                        <t:template>
                            <Text text="{TabModel>product}" />
                        </t:template>
                    </t:Column>

                    
                      <t:Column tooltip="Material Description" width="12rem">
                        <Label text="Material Description" />
                        <t:template>
                            <Text text="{TabModel>productdescription}" />
                        </t:template>
                    </t:Column>


                        <t:Column tooltip="Box No" width="4rem">
                        <Label text="Box No" />
                        <t:template>
                            <Text text="{TabModel>boxno}" />
                        </t:template>
                    </t:Column>


                    <t:Column tooltip="Material Document No" width="12rem">
                        <Label text="Material Document No" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno_gi}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Shift" width="4rem">
                        <Label text="Shift" />
                        <t:template>
                            <Text text="{TabModel>shift}" />
                        </t:template>
                    </t:Column>  

                    <t:Column tooltip="AIS Shift" width="4rem">
                        <Label text="AIS Shift" />
                        <t:template>
                            <Text text="{TabModel>aisshift}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Box No" width="5rem">
                        <Label text="Box No" />
                        <t:template>
                            <Text text="{TabModel>boxno}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Average Weight" width="8rem">
                        <Label text="Average Weight" />
                        <t:template>
                            <Text text="{TabModel>averagewt}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="ATS Weight" width="8rem">
                        <Label text="ATS Weight" />
                        <t:template>
                            <Text text="{TabModel>atsweight}" />
                        </t:template>
                    </t:Column>

                        <t:Column tooltip="Quantity in KGS" width="10rem">
                        <Label text="Quantity in KGS" />
                        <t:template>
                            <Text text="{TabModel>qtylitre}" />
                        </t:template>
                    </t:Column>

                      <t:Column tooltip="AIS Wastage in KGS" width="10rem">
                        <Label text="AIS Wastage in KGS" />
                        <t:template>
                            <Text text="{TabModel>aiswastage}" />
                        </t:template>
                    </t:Column>


                      <t:Column tooltip="AIS Wastage in Lakhs" width="11rem">
                        <Label text="AIS Wastage in Lakhs" />
                        <t:template>
                            <Text text="{TabModel>wastageinlac}" />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Grade AIS" width="6rem">
                        <Label text="Grade AIS" />
                        <t:template>
                            <Text text="{TabModel>grageais}" />
                        </t:template>
                    </t:Column>
   

                        <t:Column tooltip="Grade ATS" width="6rem">
                        <Label text="Grade ATS" />
                        <t:template>
                            <Text text="{TabModel>gradeats}" />
                        </t:template>
                    </t:Column>


                        <t:Column tooltip="Customer Code" width="8rem">
                        <Label text="Customer Code" />
                        <t:template>
                            <Text text="{TabModel>customer}" />
                        </t:template>
                    </t:Column>


                           <t:Column tooltip="Material Code" width="8rem">
                        <Label text="Material Code" />
                        <t:template>
                            <Text text="{TabModel>product}" />
                        </t:template>
                    </t:Column>


                         <t:Column tooltip="QA Name" width="8rem">
                        <Label text="QA Name" />
                        <t:template>
                            <Text text="{TabModel>qaname}" />
                        </t:template>
                    </t:Column>

                <t:Column tooltip="Operator Name" width="8rem">
                    <Label text="Operator Name" />
                    <t:template>
                        <Text text="{TabModel>operatorname}" />
                    </t:template>
                </t:Column>
                
                    <t:Column tooltip="Cummulative Qty" width="8rem">
                        <Label text="Cummulative QTY" />
                        <t:template>
                            <Text text="{TabModel>cumqty}" />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="Cumulative Entry" width="6rem">
                        <Label text="Cumulative Entry" />
                        <t:template>
                            <Text text="{TabModel>cumulativeentry}" />
                        </t:template>
                    </t:Column>

                             <t:Column tooltip="A grade QTY" width="6rem">
                        <Label text="A grade QTY" />
                        <t:template>
                            <Text text="{TabModel>agradeqty}" />
                        </t:template>
                    </t:Column>

        
                    <t:Column tooltip="HFX" width="8rem">
                        <Label text="HFX" />
                        <t:template>
                            <Text text="{TabModel>hfx}" />
                        </t:template>
                    </t:Column>

                    
                    <t:Column tooltip="Floor Wastage" width="8rem">
                        <Label text="Floor Wastage" />
                        <t:template>
                            <Text text="{TabModel>floorwaste}" />
                        </t:template>
                        </t:Column>



                    <t:Column tooltip="Weight" width="6rem">
                        <Label text="Weight" />
                        <t:template>
                            <Text text="{TabModel>weight}" />
                        </t:template>
                    </t:Column>


                  
                    <t:Column tooltip="Remarks" width="6rem">
                        <Label text="Remarks" />
                        <t:template>
                            <Text text="{TabModel>remarks}" />
                        </t:template>
                    </t:Column>


                   <t:Column tooltip="GI Material Document No" width="12rem">
                        <Label text="GI Material Document No" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno_gi}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="GI Material Document Year" width="12rem">
                        <Label text="GI Material Document Year" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentyear_gi}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="GR Material Document No" width="12rem">
                        <Label text="GR Material Document No" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentno_gr}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="GR Material Document Year" width="12rem">
                        <Label text="GR Material Document Year" />
                        <t:template>
                            <Text text="{TabModel>materialdocumentyear_gr}" />
                        </t:template>
                    </t:Column>

                <t:Column visible="false" tooltip="Status" width="8rem">
                    <Label text="Status" />
                    <t:template>
                        <Text text="{TabModel>status}" />
                    </t:template>
                </t:Column>

                <t:Column visible="false" tooltip="Item Status" width="8rem">
                    <Label text="Item Status" />
                    <t:template>
                        <Text text="{TabModel>itemstatus}" />
                    </t:template>
                </t:Column>

                <!-- <t:Column tooltip="Location 1" width="10rem">
                    <Label text="Location 1"/>
                    <t:template>
                        <Input value="{TabModel>Location1}" editable="true" placeholder="Enter Location 1"/>
                    </t:template>
                </t:Column>

                <t:Column tooltip="Location 2" width="10rem">
                    <Label text="Location 2"/>
                    <t:template>
                        <Input value="{TabModel>Location2}" editable="true" placeholder="Enter Location 2"/>
                    </t:template>
                </t:Column>

                <t:Column tooltip="Location 3" width="10rem">
                    <Label text="Location 3"/>
                    <t:template>
                        <Input value="{TabModel>Location3}" editable="true" placeholder="Enter Location 3"/>
                    </t:template>
                </t:Column>

                <t:Column tooltip="Location 4" width="10rem">
                    <Label text="Location 4"/>
                    <t:template>
                        <Input value="{TabModel>Location4}" editable="true" placeholder="Enter Location 4"/>
                    </t:template>
                </t:Column> -->

                <t:Column tooltip="Major" width="10rem">
                    <Label text="Major"/>
                    <t:template>
                        <Input value="{TabModel>Location1}"
                            visible="{= !${TabModel>isTotalRow} }"
                            editable="{= !${TabModel>Location1} }"
                            placeholder="Enter Major"/>
                    </t:template>
                </t:Column>

                <t:Column tooltip="Minor" width="10rem">
                    <Label text="Minor"/>
                    <t:template>
                        <Input value="{TabModel>Location2}"
                            visible="{= !${TabModel>isTotalRow} }"
                            editable="{= !${TabModel>Location2} }"
                            placeholder="Enter Minor"/>
                    </t:template>
                </t:Column>

                <t:Column tooltip="Critical" width="10rem">
                    <Label text="Critical"/>
                    <t:template>
                        <Input value="{TabModel>Location3}"
                            visible="{= !${TabModel>isTotalRow} }"
                            editable="{= !${TabModel>Location3} }"
                            placeholder="Enter Critical"/>
                    </t:template>
                </t:Column>

                <t:Column tooltip="Remarks" width="10rem">
                    <Label text="Remarks Defects"/>
                    <t:template>
                        <Input value="{TabModel>Location4}"
                            visible="{= !${TabModel>isTotalRow} }"
                            editable="{= !${TabModel>Location4} }"
                            placeholder="Enter Remarks"/>
                    </t:template>
                </t:Column>

                </t:columns>

            </t:Table>
        </f:content>
        <f:footer>
        <Toolbar>
            <ToolbarSpacer />

             <!-- <Button
            text="Delete All"
            type="Reject"                
            press=".deleteAllFields" />  -->
            
            <Button
                text="Save"
                type="Emphasized"
                press=".onRowSave" />
        </Toolbar>
        </f:footer>
        <!-- DynamicPage Footer -->
    </f:DynamicPage>


</mvc:View>
